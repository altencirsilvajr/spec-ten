    }

    private static IReadOnlyList<PhoneSearchResult> FindExactSearchMatches(IReadOnlyList<PhoneSearchResult> phones, string? query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return [];
        }

        return phones
            .Where(phone => IsExactSearchMatch(phone, query))
            .ToList();
    }

    private static bool IsExactSearchMatch(PhoneSearchResult result, string? query)
    {
        var normalizedQuery = PhoneSearchText.Normalize(query);
        if (normalizedQuery.Length == 0)
        {
            return false;
        }

        var normalizedBrand = PhoneSearchText.Normalize(result.Brand);
        var normalizedModel = PhoneSearchText.Normalize(result.ModelName);
        var normalizedName = PhoneSearchText.Normalize(result.Name);
        var normalizedFullName = PhoneSearchText.Normalize(result.FullName);
        var normalizedQueryWithoutBrand = StripLeadingBrand(normalizedQuery, normalizedBrand);

        var queryForms = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            normalizedQuery,
        };

        if (normalizedQueryWithoutBrand.Length > 0)
        {
            queryForms.Add(normalizedQueryWithoutBrand);
        }

        var candidateForms = new[]
        {
            normalizedModel,
            normalizedName,
            normalizedFullName,
            StripLeadingBrand(normalizedModel, normalizedBrand),
            StripLeadingBrand(normalizedName, normalizedBrand),
            StripLeadingBrand(normalizedFullName, normalizedBrand),
        };

        return candidateForms
            .Where(form => !string.IsNullOrWhiteSpace(form))
            .Any(queryForms.Contains);
    }

    private static bool IsStrongSearchMatch(PhoneSearchResult result, string query)
    {
        var normalizedQuery = PhoneSearchText.Normalize(query);
        if (normalizedQuery.Length == 0)
        {
            return false;
        }

        var normalizedBrand = PhoneSearchText.Normalize(result.Brand);
        var normalizedModel = PhoneSearchText.Normalize(result.ModelName);
        var normalizedName = PhoneSearchText.Normalize(result.Name);
        var normalizedFullName = PhoneSearchText.Normalize(result.FullName);
        var normalizedQueryWithoutBrand = StripLeadingBrand(normalizedQuery, normalizedBrand);

        var queryForms = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            normalizedQuery,
        };
        if (normalizedQueryWithoutBrand.Length > 0)
        {
            queryForms.Add(normalizedQueryWithoutBrand);
        }

        var candidateForms = new[]
        {
            normalizedModel,
            normalizedName,
            normalizedFullName,
            StripLeadingBrand(normalizedModel, normalizedBrand),
            StripLeadingBrand(normalizedName, normalizedBrand),
            StripLeadingBrand(normalizedFullName, normalizedBrand),
        };

        return candidateForms
            .Where(form => !string.IsNullOrWhiteSpace(form))
            .Any(candidate => queryForms.Any(queryForm => candidate.StartsWith(queryForm, StringComparison.OrdinalIgnoreCase)));
    }

    private static string FeaturedMatchDescription(PhoneSearchResult phone)
    {
        if (!phone.HasFullCatalogEntry)
        {
            return "Encontramos o modelo certo na cobertura ampla. Abra a ficha para consolidar imagem, specs e comparacao publica.";
        }

        if (!phone.IsPublicReady)
        {
            return $"Ficha parcial · {phone.ReadinessNote}";
        }

        var releaseLabel = phone.ReleasedAt is null
            ? "Data ainda nao publicada"
            : $"Lancado em {phone.ReleasedAt:MMM yyyy}";

        return $"{releaseLabel} · {phone.SpecCount} specs publicadas · confianca minima {phone.MinConfidence.ToString("P0")}";
    }

    private static string CardMeta(PhoneSearchResult phone)
    {
        if (!phone.HasFullCatalogEntry)
        {
            return "Modelo encontrado na busca ampla. Ficha completa em preparacao.";
        }

        if (!phone.IsPublicReady)
        {
            return $"Ficha parcial · {phone.TrustLabel} · {phone.ReadinessNote}";
        }

        var parts = new List<string>
        {
            FormatRelease(phone.ReleasedAt),
        };

        if (phone.LaunchPriceUsd is not null)
        {
            parts.Add($"US$ {phone.LaunchPriceUsd.Value:0} no lancamento");
        }

        parts.Add($"{phone.TrustLabel} · confianca {phone.MinConfidence.ToString("P0")}");
        parts.Add(FreshnessFormatter.UpdatedLabel(phone.UpdatedAt));
        return string.Join(" · ", parts);
    }

    private static CompareSelectionItem ToCompareSelectionItem(PhoneSearchResult phone)
    {
        return new CompareSelectionItem(
            phone.Id,
            phone.Brand,
            phone.BrandSlug,
            phone.Name,
            phone.Slug,
            phone.Tier,
            phone.HasFullCatalogEntry);
    }

    private static string SuggestionId(int index)
    {
        return $"catalog-suggestion-{index}";
    }

    private static string SectionAnchor(string title)
    {
        return $"catalog-{Slugger.Slugify(title)}";
    }

    private static string StripLeadingBrand(string value, string normalizedBrand)
    {
        if (value.Length == 0 || normalizedBrand.Length == 0)
        {
            return value;
        }

        return value.StartsWith(normalizedBrand, StringComparison.OrdinalIgnoreCase)
            ? value[normalizedBrand.Length..]
            : value;
    }

    private static string CompactChipset(string? chipset)
    {
        var compact = PhoneNameFormatter.CompactChipset(chipset);
        return string.IsNullOrWhiteSpace(compact) ? "-" : compact;
    }

