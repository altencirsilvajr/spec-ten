@page "/celulares"
@rendermode InteractiveServer
@implements IDisposable
@inject CatalogService CatalogService
@inject CompareSelectionState CompareSelection
@inject NavigationManager Navigation

<PageTitle>Catalogo de celulares</PageTitle>
<HeadContent>
    <meta name="description" content="Busca instantanea de celulares com categorias claras, comparacao guiada e fonte por especificacao." />
    <link rel="canonical" href="/celulares" />
</HeadContent>

<section class="catalog-hero tool-hero @(IsCatalogHeroCompact ? "compact" : null)">
    <div>
        <p class="eyebrow">Catalogo publico</p>
        <h1 class="page-title">Encontre o modelo certo sem sofrer na responsividade.</h1>
        <p class="page-lede">Busca por nome, marca ou chipset, cobertura ampliada para modelos recentes e ficha tecnica organizada para celular e desktop.</p>
    </div>
</section>

<section class="catalog-toolbar">
    <div class="toolbar-search-panel">
        <div class="toolbar-search">
            <label for="catalog-search">Buscar aparelho</label>
            <div class="search-input-shell">
                <input id="catalog-search"
                       value="@SearchText"
                       @oninput="OnSearchChanged"
                       @onfocus="OnSearchFocused"
                       @onblur="OnSearchBlur"
                       @onkeydown="OnSearchKeyDown"
                       autocomplete="off"
                       autocapitalize="off"
                       autocorrect="off"
                       spellcheck="false"
                       inputmode="search"
                       role="combobox"
                       aria-autocomplete="list"
                       aria-expanded="@(HasSuggestions ? "true" : "false")"
                       aria-controls="catalog-suggestions"
                       aria-activedescendant="@ActiveSuggestionId"
                       placeholder="Xiaomi 15T Pro, Galaxy A56, A18 Pro..." />
                <button class="button primary" type="button" @onclick="ApplyFiltersAndFocusResultsAsync">Ir para resultados</button>
            </div>

            <div class="search-assist-strip @SearchAssistTone" aria-live="polite">
                <strong>@SearchAssistTitle</strong>
                <span>@SearchAssistMessage</span>
            </div>

            @if (HasSuggestions)
            {
                <div id="catalog-suggestions" class="suggestion-panel" role="listbox" aria-label="Sugestoes de busca">
                    @for (var index = 0; index < Suggestions.Count; index++)
                    {
                        var suggestion = Suggestions[index];
                        var isActive = ActiveSuggestionIndex == index;
                        <button class="suggestion-item @(isActive ? "active" : null)"
                                id="@SuggestionId(index)"
                                role="option"
                                aria-selected="@isActive"
                                type="button"
                                @onclick="() => OpenSuggestion(suggestion)">
                            <span class="suggestion-title">@suggestion.FullName</span>
                            <span class="suggestion-meta">@SuggestionMeta(suggestion)</span>
                        </button>
                    }
                    <button class="suggestion-item more @(ActiveSuggestionIndex == Suggestions.Count ? "active" : null)"
                            id="@SuggestionId(Suggestions.Count)"
                            role="option"
                            aria-selected="@(ActiveSuggestionIndex == Suggestions.Count)"
                            type="button"
                            @onclick="ApplyFiltersAndFocusResultsAsync">
                        <span class="suggestion-title">Ir para os cards filtrados</span>
                        <span class="suggestion-meta">Fechar sugestoes e continuar no catalogo</span>
                    </button>
                </div>
            }
        </div>
    </div>

    <button class="button subtle compact mobile-filter-toggle"
            type="button"
            aria-expanded="@IsMobileFiltersOpen"
            @onclick="ToggleMobileFilters">
        @(IsMobileFiltersOpen ? "Fechar filtros" : "Refinar filtros")
    </button>

    <div class="toolbar-filter-panel @(IsMobileFiltersOpen ? "mobile-open" : "mobile-collapsed")">
        <div class="toolbar-filters">
            <label for="catalog-brand">
                <span class="filter-label">Marca</span>
                <select id="catalog-brand" value="@SelectedBrandSlug" @onchange="OnBrandChanged">
                    <option value="">Todas as marcas</option>
                    @foreach (var brand in BrandOptions)
                    {
                        <option value="@brand.Slug">@brand.Name (@brand.Count)</option>
                    }
                </select>
            </label>

            <label for="catalog-sort">
                <span class="filter-label">Ordenar por</span>
                <select id="catalog-sort" value="@SelectedSortKey" @onchange="OnSortChanged">
                    @foreach (var option in SortOptions)
                    {
                        <option value="@option.Key">@option.Label</option>
                    }
                </select>
            </label>

            <div>
                <span class="filter-label">Faixa</span>
                <div class="segmented-control" role="tablist" aria-label="Faixa de aparelho">
                    @foreach (var option in TierOptions)
                    {
                        <button type="button"
                                role="tab"
                                aria-selected="@(SelectedTierKey == option.Key)"
                                class="segment @(SelectedTierKey == option.Key ? "active" : null)"
                                @onclick="() => SetTierAsync(option.Key)">
                            @option.Label
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@if (Sections.Count > 1)
{
    <nav class="section-jumpbar catalog-jumpbar" aria-label="Ir para categoria do catalogo">
        <strong class="jumpbar-label">Ir para categoria</strong>
        <div class="jumpbar-list">
            @foreach (var catalogGroup in Sections)
            {
                <a class="jump-chip" href="@($"#{SectionAnchor(catalogGroup.Title)}")">
                    <span>@catalogGroup.Title</span>
                    <span>@catalogGroup.Count</span>
                </a>
            }
        </div>
    </nav>
}

<section id="catalog-results" class="catalog-summary-line" aria-live="polite">
    <div>
        <strong>@ResultHeading</strong>
        <span>@ResultDescription</span>
    </div>
    <button class="button subtle compact" type="button" @onclick="ClearFiltersAsync">Limpar filtros</button>
</section>

@if (ActiveFilters.Count > 0)
{
    <section class="active-filter-bar" aria-label="Filtros ativos">
        <strong>Filtros ativos</strong>
        <div class="active-filter-list">
            @foreach (var filter in ActiveFilters)
            {
                <button class="active-filter-chip" type="button" @onclick="() => RemoveFilterAsync(filter.Key)">
                    <span>@filter.Label</span>
                    <span aria-hidden="true">x</span>
                </button>
            }
        </div>
    </section>
}

@if (CompareSelection.Count > 0)
{
    <section class="compare-dock" aria-label="Comparacao pronta">
        <div class="compare-dock-copy">
            <strong>@CompareSelection.Count aparelho(s) selecionado(s)</strong>
            <p>@CompareHint</p>
            <div class="selected-chip-list">
                @foreach (var selected in CompareSelection.Items)
                {
                    <button class="selected-chip" type="button" @onclick="() => RemoveSelected(selected.Id)">
                        <span>@selected.FullName</span>
                        <span aria-hidden="true">x</span>
                    </button>
                }
            </div>
        </div>
        <div class="compare-dock-actions">
            <button class="button subtle" type="button" @onclick="ClearSelection">Limpar selecao</button>
            <button class="button primary" type="button" disabled="@(!CanCompare)" @onclick="CompareSelected">
                Comparar agora
            </button>
        </div>
    </section>
}

@if (FeaturedMatch is not null)
{
    var featuredMatch = FeaturedMatch;
    var isSelected = CompareSelection.Contains(featuredMatch.Id);
    var selectionLimitReached = CompareSelection.Count >= 4 && !isSelected;

    <section class="featured-match-panel" aria-label="Melhor correspondencia">
        <a class="featured-match-media media-frame" href="/celulares/@featuredMatch.BrandSlug/@featuredMatch.Slug" aria-label="@featuredMatch.FullName">
            <PhoneMediaContent ImageUrl="@featuredMatch.ImageUrl"
                               Alt="@featuredMatch.FullName"
                               Brand="@featuredMatch.DisplayBrand"
                               Model="@featuredMatch.ModelName"
                               Loading="eager" />
        </a>

        <div class="featured-match-copy">
            <div class="featured-match-heading">
                <div>
                    <p class="eyebrow">Melhor correspondencia</p>
                    <h2>@featuredMatch.FullName</h2>
                    <p class="muted">@FeaturedMatchDescription(featuredMatch)</p>
                </div>
                <span class="tier">@featuredMatch.PrimaryBadgeLabel</span>
            </div>

            @if (featuredMatch.HasFullCatalogEntry)
            {
                <dl class="spec-pills catalog-spec-pills">
                    <div>
                        <dt>Chipset</dt>
                        <dd>@CompactChipset(featuredMatch.Chipset)</dd>
                    </div>
                    <div>
                        <dt>Tela</dt>
                        <dd>@(featuredMatch.Display ?? "-")</dd>
                    </div>
                    <div>
                        <dt>Camera</dt>
                        <dd>@(featuredMatch.MainCamera ?? "-")</dd>
                    </div>
                    <div>
                        <dt>Bateria</dt>
                        <dd>@(featuredMatch.Battery ?? "-")</dd>
                    </div>
                </dl>

                @if (!featuredMatch.IsPublicReady)
                {
                    <p class="placeholder-note">@featuredMatch.ReadinessNote</p>
                }
            }
            else
            {
                <p class="placeholder-note">Esta foi a melhor correspondencia encontrada na cobertura ampla. Ao abrir, o sistema tenta completar a ficha publica com imagem e specs consolidadas.</p>
            }

            <div class="card-actions">
                <a class="button primary" href="/celulares/@featuredMatch.BrandSlug/@featuredMatch.Slug">@(featuredMatch.IsPublicReady ? "Ver ficha" : featuredMatch.HasFullCatalogEntry ? "Abrir ficha parcial" : "Completar e abrir ficha")</a>
                @if (featuredMatch.IsPublicReady)
                {
                    <button class="button @(isSelected ? "primary" : "subtle")"
                            type="button"
                            aria-pressed="@isSelected"
                            disabled="@selectionLimitReached"
                            @onclick="() => ToggleSelected(featuredMatch)">
                        @(isSelected ? "Selecionado para comparar" : selectionLimitReached ? "Limite de 4" : "Selecionar para comparar")
                    </button>
                }
            </div>
        </div>
    </section>
}

@if (Sections.Count == 0)
{
    <section class="empty-state">
        <h2>Nenhum aparelho encontrado</h2>
        <p class="muted">Tente buscar por marca, linha ou chipset. Exemplos: Xiaomi 15T Pro, Galaxy A56, Dimensity 9400+.</p>
        <div class="empty-state-actions">
            @if (!string.IsNullOrWhiteSpace(SearchText))
            {
                <a class="button subtle" href="@BuildCatalogUrl(null, SelectedTierKey, SelectedBrandSlug, SelectedSortKey, CatalogResultsFragment)">Remover so a busca</a>
            }

            <button class="button primary" type="button" @onclick="ClearFiltersAsync">Limpar filtros</button>
        </div>

        @if (EmptyStateSuggestions.Count > 0 || EmptyStatePhones.Count > 0 || FeaturedBrandOptions.Count > 0)
        {
            <div class="empty-state-recovery">
                <strong>Atalhos para destravar a busca</strong>
                <p class="muted">Abra um modelo parecido ou volte por marcas com cobertura forte para nao cair em um beco sem saida.</p>

                <div class="selected-chip-list">
                    @foreach (var suggestion in EmptyStateSuggestions)
                    {
                        <a class="jump-chip" href="/celulares/@suggestion.BrandSlug/@suggestion.Slug">
                            <span>@suggestion.FullName</span>
                            <span>@suggestion.PrimaryBadgeLabel</span>
                        </a>
                    }

                    @if (EmptyStateSuggestions.Count == 0)
                    {
                        @foreach (var phone in EmptyStatePhones)
                        {
                            <a class="jump-chip" href="/celulares/@phone.BrandSlug/@phone.Slug">
                                <span>@phone.FullName</span>
                                <span>@phone.Tier</span>
                            </a>
                        }
                    }

                    @foreach (var brand in FeaturedBrandOptions.Take(3))
                    {
                        <a class="jump-chip" href="@BuildCatalogUrl(null, SelectedTierKey, brand.Slug, SelectedSortKey, CatalogResultsFragment)">
                            <span>@brand.Name</span>
                            <span>@brand.Count</span>
                        </a>
                    }
                </div>
            </div>
        }
    </section>
}
else
{
    @foreach (var catalogSection in Sections)
    {
        <section id="@SectionAnchor(catalogSection.Title)" class="catalog-section">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">@catalogSection.Count aparelhos</p>
                    <h2>@catalogSection.Title</h2>
                </div>
                @if (!string.IsNullOrWhiteSpace(catalogSection.Description))
                {
                    <p class="muted">@catalogSection.Description</p>
                }
            </div>

            <div class="section-progress-line" aria-live="polite">
                <strong>@SectionVisibilitySummary(catalogSection)</strong>
                @if (IsSectionCollapsed(catalogSection))
                {
                    <span class="muted">Esta categoria fica recolhida por padrao para priorizar os modelos com ficha completa.</span>
                }
                else if (SectionHasOverflow(catalogSection))
                {
                    <span class="muted">Continue abrindo a categoria sem perder o contexto da pagina.</span>
                }
            </div>

            @if (IsSectionCollapsed(catalogSection))
            {
                <p class="section-collapsed-note">Abrimos essa camada apenas quando voce quiser explorar modelos que ainda estao sem a ficha tecnica consolidada.</p>
            }
            else
            {
                <div class="phone-grid catalog-grid">
                    @foreach (var phone in VisibleSectionPhones(catalogSection))
                    {
                        var isSelected = CompareSelection.Contains(phone.Id);
                        var selectionLimitReached = CompareSelection.Count >= 4 && !isSelected;

                        <article class="phone-card catalog-card @(isSelected ? "selected" : null)">
                            <a class="phone-card-media media-frame" href="/celulares/@phone.BrandSlug/@phone.Slug" aria-label="@phone.FullName">
                                <PhoneMediaContent ImageUrl="@phone.ImageUrl"
                                                   Alt="@phone.FullName"
                                                   Brand="@phone.DisplayBrand"
                                                   Model="@phone.ModelName" />
                            </a>

                            <div class="phone-card-body">
                                <div class="catalog-card-header">
                                    <div>
                                        <p class="muted">@phone.DisplayBrand</p>
                                        <h3><a href="/celulares/@phone.BrandSlug/@phone.Slug">@phone.ModelName</a></h3>
                                        <p class="catalog-meta">@CardMeta(phone)</p>
                                    </div>
                                    <span class="tier">@phone.PrimaryBadgeLabel</span>
                                </div>

                                @if (phone.HasFullCatalogEntry)
                                {
                                    <dl class="spec-pills catalog-spec-pills">
                                        <div>
                                            <dt>Chipset</dt>
                                            <dd>@CompactChipset(phone.Chipset)</dd>
                                        </div>
                                        <div>
                                            <dt>Tela</dt>
                                            <dd>@(phone.Display ?? "-")</dd>
                                        </div>
                                        <div>
                                            <dt>Camera</dt>
                                            <dd>@(phone.MainCamera ?? "-")</dd>
                                        </div>
                                        <div>
                                            <dt>Bateria</dt>
                                            <dd>@(phone.Battery ?? "-")</dd>
                                        </div>
                                    </dl>

                                    @if (!phone.IsPublicReady)
                                    {
                                        <p class="placeholder-note">@phone.ReadinessNote</p>
                                    }
                                }
                                else
                                {
                                    <p class="placeholder-note">Encontramos este modelo na busca ampla. Ao abrir, o sistema tenta completar a ficha publica com imagem e specs consolidadas.</p>
                                }

                                <div class="card-actions">
                                    <a class="button subtle" href="/celulares/@phone.BrandSlug/@phone.Slug">@(phone.IsPublicReady ? "Ver ficha" : phone.HasFullCatalogEntry ? "Abrir ficha parcial" : "Abrir ficha completa")</a>
                                    @if (phone.IsPublicReady)
                                    {
                                        <button class="button @(isSelected ? "primary" : "subtle")"
                                                type="button"
                                                aria-pressed="@isSelected"
                                                disabled="@selectionLimitReached"
                                                @onclick="() => ToggleSelected(phone)">
                                            @(isSelected ? "Selecionado" : selectionLimitReached ? "Limite de 4" : "Selecionar para comparar")
                                        </button>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }

            @if (SectionHasOverflow(catalogSection) || CanCollapseSection(catalogSection) || CanHideSection(catalogSection))
            {
                <div class="section-more-actions">
                    @if (IsSectionCollapsed(catalogSection))
                    {
                        <button class="button subtle"
                                type="button"
                                @onclick="() => ShowMoreInSection(catalogSection)">
                            Mostrar cobertura inicial
                        </button>
                    }
                    else
                    {
                        @if (SectionHasOverflow(catalogSection))
                        {
                            <button class="button subtle"
                                    type="button"
                                    @onclick="() => ShowMoreInSection(catalogSection)">
                                Mostrar mais @SectionRevealCount(catalogSection) aparelho(s)
                            </button>
                        }

                        @if (CanCollapseSection(catalogSection))
                        {
                            <button class="button subtle"
                                    type="button"
                                    @onclick="() => ShowLessInSection(catalogSection)">
                                Mostrar menos
                            </button>
                        }

                        @if (CanHideSection(catalogSection))
                        {
                            <button class="button subtle"
                                    type="button"
                                    @onclick="() => HideSection(catalogSection)">
                                Ocultar cobertura inicial
                            </button>
                        }
                    }
                </div>
            }
        </section>
    }

    <section class="catalog-metrics catalog-metrics-strip" aria-label="Resumo do catalogo">
        <div>
            <strong>@Phones.Count</strong>
            <span>modelos visiveis</span>
        </div>
        <div>
            <strong>@CompareSelection.Count</strong>
            <span>na comparacao</span>
        </div>
        <div>
            <strong>@MaxSpecs</strong>
            <span>specs por aparelho</span>
        </div>
    </section>

    @if (!HasCatalogFilters && FeaturedBrandOptions.Count > 0)
    {
        <section class="brand-quick-strip" aria-label="Marcas com ficha completa">
            <strong class="jumpbar-label">Marcas com ficha completa</strong>
            <div class="jumpbar-list">
                <button class="jump-chip @(string.IsNullOrWhiteSpace(SelectedBrandSlug) ? "active" : null)"
                        type="button"
                        aria-pressed="@string.IsNullOrWhiteSpace(SelectedBrandSlug)"
                        @onclick="() => SetBrandAsync(string.Empty)">
                    <span>Todas</span>
                    <span>@FeaturedBrandOptions.Sum(option => option.Count)</span>
                </button>

                @foreach (var brand in FeaturedBrandOptions)
                {
                    <button class="jump-chip @(SelectedBrandSlug == brand.Slug ? "active" : null)"
                            type="button"
                            aria-pressed="@(SelectedBrandSlug == brand.Slug)"
                            @onclick="() => SetBrandAsync(brand.Slug)">
                        <span>@brand.Name</span>
                        <span>@brand.Count</span>
                    </button>
                }
            </div>
        </section>
    }

    @if (ShowPopularComparisons)
    {
        <section class="catalog-section compare-preset-section" aria-label="Comparacoes prontas">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Atalho publico</p>
                    <h2>Comparacoes prontas</h2>
                </div>
                <p class="muted">Entradas diretas para quem quer comparar sem montar a selecao manualmente logo de cara.</p>
            </div>

            <div class="compare-preset-grid">
                @foreach (var preset in PopularComparisons)
                {
                    <article class="compare-preset-card">
                        <div class="compare-preset-copy">
                            <span class="tier">@preset.Label</span>
                            <h3>@PresetTitle(preset)</h3>
                            <p class="muted">@preset.Reason</p>
                        </div>

                        <div class="compare-preset-versus" aria-label="@PresetTitle(preset)">
                            <div class="compare-preset-side">
                                <span>@preset.Left.DisplayBrand</span>
                                <strong>@preset.Left.ModelName</strong>
                                <small>@PresetPhoneMeta(preset.Left)</small>
                            </div>
                            <span class="compare-preset-vs" aria-hidden="true">vs</span>
                            <div class="compare-preset-side">
                                <span>@preset.Right.DisplayBrand</span>
                                <strong>@preset.Right.ModelName</strong>
                                <small>@PresetPhoneMeta(preset.Right)</small>
                            </div>
                        </div>

                        <a class="button primary" href="@PresetCompareUrl(preset)">Abrir comparacao</a>
                    </article>
                }
            </div>
        </section>
    }
}

@code {
    [SupplyParameterFromQuery(Name = "busca")]
    public string? Busca { get; set; }

    [SupplyParameterFromQuery(Name = "classe")]
    public string? Classe { get; set; }

    [SupplyParameterFromQuery(Name = "marca")]
    public string? Marca { get; set; }

    [SupplyParameterFromQuery(Name = "ordem")]
    public string? Ordem { get; set; }

    private static readonly IReadOnlyList<FilterOption> TierOptions =
    [
        new("", "Todas"),
        new("top", "Top de linha"),
        new("intermediario", "Intermediarios"),
        new("entrada", "Entrada"),
    ];

    private static readonly IReadOnlyList<FilterOption> SortOptions =
    [
        new("auto", "Automatico"),
        new("newest", "Mais recentes"),
        new("confidence", "Maior confianca"),
        new("name", "Nome A-Z"),
    ];
    private const int SearchDebounceMilliseconds = 250;
    private const int SuggestionCloseDelayMilliseconds = 120;
    private const int BrowseSectionInitialSize = 4;
    private const int FilteredSectionInitialSize = 8;
    private const int SectionRevealStep = 8;
    private const int SearchResultLimit = 240;
    private const string CatalogResultsFragment = "catalog-results";

    private IReadOnlyList<PhoneSearchResult> Phones { get; set; } = [];
    private IReadOnlyList<PhoneSuggestionDto> Suggestions { get; set; } = [];
    private IReadOnlyList<CatalogBrandOptionDto> BrandOptions { get; set; } = [];
    private IReadOnlyList<CatalogBrandOptionDto> FeaturedBrandOptions { get; set; } = [];
    private IReadOnlyList<PhoneSearchResult> QuickStartPhones { get; set; } = [];
    private IReadOnlyList<ComparisonQuickStartDto> PopularComparisons { get; set; } = [];
    private IReadOnlyList<CatalogSectionViewModel> Sections { get; set; } = [];
    private Dictionary<string, int> SectionVisibleCounts { get; } = [];
    private string SearchText { get; set; } = "";
    private string SelectedTierKey { get; set; } = "";
    private string SelectedBrandSlug { get; set; } = "";
    private string SelectedSortKey { get; set; } = "auto";
    private int ActiveSuggestionIndex { get; set; } = -1;
    private bool IsSearchRefreshing { get; set; }
    private CancellationTokenSource? _searchDebounceCts;
    private CancellationTokenSource? _suggestionCloseCts;
    private long _searchRefreshVersion;
    private bool IsSuggestionPanelOpen { get; set; }
    private bool IsMobileFiltersOpen { get; set; }

    private bool HasSuggestions => IsSuggestionPanelOpen && Suggestions.Count > 0 && !string.IsNullOrWhiteSpace(SearchText);
    private bool CanCompare => CompareSelection.Count is >= 2 and <= 4;
    private int SuggestionOptionCount => HasSuggestions ? Suggestions.Count + 1 : 0;
    private string? ActiveSuggestionId => ActiveSuggestionIndex >= 0 ? SuggestionId(ActiveSuggestionIndex) : null;
    private int MaxSpecs => Phones.Count == 0 ? 0 : Phones.Max(phone => phone.SpecCount);
    private bool HasCatalogFilters => !string.IsNullOrWhiteSpace(SearchText) ||
                                      !string.IsNullOrWhiteSpace(SelectedTierKey) ||
                                      !string.IsNullOrWhiteSpace(SelectedBrandSlug);
    private bool ResultLimitReached => Phones.Count >= SearchResultLimit;
    private string ResultHeading => string.IsNullOrWhiteSpace(SearchText) && string.IsNullOrWhiteSpace(SelectedTierKey) && string.IsNullOrWhiteSpace(SelectedBrandSlug)
        ? "Catalogo dividido por faixa"
        : $"{Phones.Count} resultado(s)";
    private string ResultDescription => string.IsNullOrWhiteSpace(SearchText) && string.IsNullOrWhiteSpace(SelectedTierKey) && string.IsNullOrWhiteSpace(SelectedBrandSlug)
        ? "Top de linha, intermediarios e entrada com o mesmo fluxo de leitura."
        : ResultLimitReached
            ? $"Mostrando ate {SearchResultLimit} resultados desta filtragem. Refine por nome, linha ou chipset para cortar ruido sem perder os modelos recentes."
        : CoverageOnlyCount == 0 && PartialPhoneCount == 0
            ? $"Busca atualizada em tempo real com marca, faixa e ordenacao em {CurrentSortLabel.ToLowerInvariant()}."
            : $"Busca atualizada em tempo real com marca, faixa e ordenacao em {CurrentSortLabel.ToLowerInvariant()}. {ReadyPhoneCount} ficha(s) pronta(s), {PartialPhoneCount} parcial(is) e {CoverageOnlyCount} em cobertura inicial.";
    private string CompareHint => CompareSelection.Count switch
    {
        1 => "Escolha mais um aparelho para habilitar a comparacao.",
        4 => "Limite de quatro modelos atingido. Remova um para trocar.",
        _ => "A comparacao fica ativa com dois a quatro modelos.",
    };
    private string CurrentSortLabel => SortOptions.First(option => option.Key == SelectedSortKey).Label;
    private IReadOnlyList<ActiveFilterViewModel> ActiveFilters => BuildActiveFilters();
    private IReadOnlyList<PhoneSuggestionDto> EmptyStateSuggestions => Suggestions.Where(item => item.IsPublicReady).Take(4).ToList();
    private IReadOnlyList<PhoneSearchResult> EmptyStatePhones => QuickStartPhones.Take(4).ToList();
    private int ReadyPhoneCount => Phones.Count(phone => phone.IsPublicReady);
    private int PartialPhoneCount => Phones.Count(phone => phone.IsPartialCatalogEntry);
    private int CoverageOnlyCount => Phones.Count(phone => !phone.HasFullCatalogEntry);
    private bool IsCatalogHeroCompact => HasCatalogFilters || CompareSelection.Count > 0;
    private bool ShowPopularComparisons => CompareSelection.Count == 0 &&
                                           string.IsNullOrWhiteSpace(SearchText) &&
                                           string.IsNullOrWhiteSpace(SelectedTierKey) &&
                                           string.IsNullOrWhiteSpace(SelectedBrandSlug) &&
                                           PopularComparisons.Count > 0;
    private int FullSuggestionCount => Suggestions.Count(item => item.IsPublicReady);
    private int PartialSuggestionCount => Suggestions.Count(item => item.IsPartialCatalogEntry);
    private int CoverageSuggestionCount => Suggestions.Count(item => !item.HasFullCatalogEntry);
    private PhoneSearchResult? FeaturedMatch => BuildFeaturedMatch();
    private SearchAssistViewModel SearchAssist => BuildSearchAssist();
    private string SearchAssistTitle => SearchAssist.Title;
    private string SearchAssistMessage => SearchAssist.Message;
    private string SearchAssistTone => SearchAssist.Tone;

    protected override async Task OnParametersSetAsync()
    {
        SearchText = Busca?.Trim() ?? "";
        SelectedTierKey = NormalizeTierKey(Classe);
        SelectedBrandSlug = NormalizeBrandSlug(Marca);
        SelectedSortKey = NormalizeSortKey(Ordem);
        if (BrandOptions.Count == 0)
        {
            BrandOptions = await CatalogService.GetBrandOptionsAsync(CancellationToken.None);
        }

        if (FeaturedBrandOptions.Count == 0)
        {
            FeaturedBrandOptions = await CatalogService.GetFeaturedBrandOptionsAsync(6, CancellationToken.None);
        }

        if (QuickStartPhones.Count == 0)
        {
            QuickStartPhones = await CatalogService.GetQuickStartPhonesAsync(6, CancellationToken.None);
        }

        if (PopularComparisons.Count == 0)
        {
            PopularComparisons = await CatalogService.GetPopularComparisonsAsync(4, CancellationToken.None);
        }

        await RefreshCatalogAsync(CancellationToken.None);
        await RefreshSuggestionsAsync(CancellationToken.None);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await CompareSelection.EnsureHydratedAsync())
        {
            return;
        }

        foreach (var phone in Phones.Where(phone => CompareSelection.Contains(phone.Id)))
        {
            CompareSelection.AddOrUpdate(ToCompareSelectionItem(phone), notify: false);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnSearchChanged(ChangeEventArgs args)
    {
        SearchText = args.Value?.ToString() ?? "";
        if (!string.IsNullOrWhiteSpace(SearchText))
        {
            OpenSuggestionPanel();
        }

        await QueueSearchRefreshAsync();
    }

