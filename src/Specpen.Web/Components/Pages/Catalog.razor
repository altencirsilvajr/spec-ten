    private void SyncFilterUrl(string? fragment = null)
    {
        var targetUrl = BuildCatalogUrl(SearchText, SelectedTierKey, SelectedBrandSlug, SelectedSortKey, fragment);
        if (string.Equals(targetUrl, Navigation.Uri, StringComparison.Ordinal))
        {
            return;
        }

        Navigation.NavigateTo(targetUrl, replace: true);
    }

    private string BuildCatalogUrl(
        string? searchText,
        string? tierKey,
        string? brandSlug,
        string? sortKey,
        string? fragment = null)
    {
        var parameters = new Dictionary<string, object?>();
        if (!string.IsNullOrWhiteSpace(searchText))
        {
            parameters["busca"] = searchText;
        }

        if (!string.IsNullOrWhiteSpace(tierKey))
        {
            parameters["classe"] = tierKey;
        }

        if (!string.IsNullOrWhiteSpace(brandSlug))
        {
            parameters["marca"] = brandSlug;
        }

        if (!string.IsNullOrWhiteSpace(sortKey) && !string.Equals(sortKey, "auto", StringComparison.OrdinalIgnoreCase))
        {
            parameters["ordem"] = sortKey;
        }

        var targetUrl = Navigation.GetUriWithQueryParameters("/celulares", parameters);
        if (!string.IsNullOrWhiteSpace(fragment))
        {
            targetUrl = $"{targetUrl}#{fragment}";
        }

        return targetUrl;
    }

    private async Task QueueSearchRefreshAsync()
    {
        CancelPendingSearchRefresh(clearBusyState: false);
        var refreshVersion = _searchRefreshVersion;
        var searchText = SearchText;
        if (string.IsNullOrWhiteSpace(SearchText))
        {
            var refresh = await LoadSearchRefreshAsync(searchText, CancellationToken.None);
            if (refreshVersion != _searchRefreshVersion)
            {
                return;
            }

            ApplyCatalogResults(refresh.Phones);
            Suggestions = [];
            ActiveSuggestionIndex = -1;
            IsSearchRefreshing = false;
            return;
        }

        var debounceCts = new CancellationTokenSource();
        _searchDebounceCts = debounceCts;
        IsSearchRefreshing = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(SearchDebounceMilliseconds, debounceCts.Token);
            var refresh = await LoadSearchRefreshAsync(searchText, debounceCts.Token);
            if (refreshVersion != _searchRefreshVersion ||
                !ReferenceEquals(_searchDebounceCts, debounceCts))
            {
                return;
            }

            ApplyCatalogResults(refresh.Phones);
            Suggestions = refresh.Suggestions;
            ResetSuggestionSelection();
        }
        catch (OperationCanceledException) when (debounceCts.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_searchDebounceCts, debounceCts))
            {
                _searchDebounceCts = null;
                IsSearchRefreshing = false;
                await InvokeAsync(StateHasChanged);
            }

            debounceCts.Dispose();
        }
    }

    private async Task RefreshCatalogAsync(CancellationToken cancellationToken)
    {
        var phones = await CatalogService.SearchForLiveDiscoveryAsync(
            SearchText,
            ParseTier(SelectedTierKey),
            SelectedBrandSlug,
            ParseSort(SelectedSortKey, SearchText),
            SearchResultLimit,
            cancellationToken);
        ApplyCatalogResults(phones);
    }

    private void ApplyCatalogResults(IReadOnlyList<PhoneSearchResult> phones)
    {
        Phones = phones;
        Sections = BuildSections(Phones);
        SyncSectionVisibility();

        foreach (var phone in Phones.Where(phone => CompareSelection.Contains(phone.Id)))
        {
            CompareSelection.AddOrUpdate(ToCompareSelectionItem(phone), notify: false);
        }
    }

    private async Task<SearchRefreshResult> LoadSearchRefreshAsync(string searchText, CancellationToken cancellationToken)
    {
        var phones = await CatalogService.SearchForLiveDiscoveryAsync(
            searchText,
            ParseTier(SelectedTierKey),
            SelectedBrandSlug,
            ParseSort(SelectedSortKey, searchText),
            SearchResultLimit,
            cancellationToken);
        var suggestions = string.IsNullOrWhiteSpace(searchText)
            ? []
            : await CatalogService.SuggestForLiveDiscoveryAsync(searchText, 8, cancellationToken);

        return new SearchRefreshResult(phones, suggestions);
    }

    private IReadOnlyList<PhoneSearchResult> VisibleSectionPhones(CatalogSectionViewModel section)
    {
        return section.Phones
            .Take(CurrentVisibleCount(section))
            .ToList();
    }

    private bool SectionHasOverflow(CatalogSectionViewModel section)
    {
        return CurrentVisibleCount(section) < section.Count;
    }

    private bool IsSectionCollapsed(CatalogSectionViewModel section)
    {
        return section.StartsCollapsed && CurrentVisibleCount(section) == 0;
    }

    private bool CanCollapseSection(CatalogSectionViewModel section)
    {
        return CurrentVisibleCount(section) > SectionMinimumVisibleCount(section);
    }

    private bool CanHideSection(CatalogSectionViewModel section)
    {
        return section.StartsCollapsed && CurrentVisibleCount(section) > 0;
    }

    private int SectionRevealCount(CatalogSectionViewModel section)
    {
        return Math.Min(SectionRevealStep, Math.Max(0, section.Count - CurrentVisibleCount(section)));
    }

    private string SectionVisibilitySummary(CatalogSectionViewModel section)
    {
        if (IsSectionCollapsed(section))
        {
            return $"{section.Count} aparelho(s) recolhido(s) em cobertura inicial";
        }

        var visibleCount = Math.Min(CurrentVisibleCount(section), section.Count);
        return visibleCount >= section.Count
            ? $"{section.Count} de {section.Count} aparelho(s) visiveis"
            : $"{visibleCount} de {section.Count} aparelho(s) visiveis";
    }

    private void ShowMoreInSection(CatalogSectionViewModel section)
    {
        var key = SectionKey(section);
        var currentCount = CurrentVisibleCount(section);
        if (section.StartsCollapsed && currentCount == 0)
        {
            SectionVisibleCounts[key] = Math.Min(section.Count, SectionInitialSize());
            return;
        }

        SectionVisibleCounts[key] = Math.Min(section.Count, currentCount + SectionRevealStep);
    }

    private void ShowLessInSection(CatalogSectionViewModel section)
    {
        SectionVisibleCounts[SectionKey(section)] = SectionMinimumVisibleCount(section);
    }

    private void HideSection(CatalogSectionViewModel section)
    {
        SectionVisibleCounts[SectionKey(section)] = 0;
    }

    private void SyncSectionVisibility()
    {
        var validKeys = Sections.Select(SectionKey).ToHashSet(StringComparer.Ordinal);
        foreach (var staleKey in SectionVisibleCounts.Keys.Where(key => !validKeys.Contains(key)).ToList())
        {
            SectionVisibleCounts.Remove(staleKey);
        }

        foreach (var section in Sections)
        {
            var key = SectionKey(section);
            var minimumVisibleCount = SectionMinimumVisibleCount(section);
            if (!SectionVisibleCounts.TryGetValue(key, out var currentCount))
            {
                SectionVisibleCounts[key] = minimumVisibleCount;
                continue;
            }

            SectionVisibleCounts[key] = Math.Min(section.Count, Math.Max(minimumVisibleCount, currentCount));
        }
    }

    private int CurrentVisibleCount(CatalogSectionViewModel section)
    {
        return SectionVisibleCounts.GetValueOrDefault(SectionKey(section), SectionMinimumVisibleCount(section));
    }

    private int SectionMinimumVisibleCount(CatalogSectionViewModel section)
    {
        return section.StartsCollapsed
            ? 0
            : Math.Min(section.Count, SectionInitialSize());
    }

    private int SectionInitialSize()
    {
        return HasCatalogFilters ? FilteredSectionInitialSize : BrowseSectionInitialSize;
    }

    private async Task RefreshSuggestionsAsync(CancellationToken cancellationToken)
    {
        Suggestions = string.IsNullOrWhiteSpace(SearchText)
            ? []
            : await CatalogService.SuggestForLiveDiscoveryAsync(SearchText, 8, cancellationToken);
        ResetSuggestionSelection();
    }

    private async Task ActivateActiveSuggestionAsync()
    {
        if (ActiveSuggestionIndex < 0 || ActiveSuggestionIndex >= SuggestionOptionCount)
        {
            await ApplyFiltersAndFocusResultsAsync();
            return;
        }

        if (ActiveSuggestionIndex < Suggestions.Count)
        {
            OpenSuggestion(Suggestions[ActiveSuggestionIndex]);
            return;
        }

        await ApplyFiltersAndFocusResultsAsync();
    }

    private void MoveActiveSuggestion(int step)
    {
        if (SuggestionOptionCount == 0)
        {
            ActiveSuggestionIndex = -1;
            return;
        }

        ActiveSuggestionIndex = ActiveSuggestionIndex < 0
            ? 0
            : (ActiveSuggestionIndex + step + SuggestionOptionCount) % SuggestionOptionCount;
    }

    private void ResetSuggestionSelection()
    {
        ActiveSuggestionIndex = Suggestions.Count > 0 ? 0 : -1;
    }

    private void OpenSuggestionPanel()
    {
        CancelPendingSuggestionClose();
        IsSuggestionPanelOpen = true;
    }

    private async Task CloseSuggestionPanelAfterDelayAsync()
    {
        CancelPendingSuggestionClose();
        var closeCts = new CancellationTokenSource();
        _suggestionCloseCts = closeCts;

        try
        {
            await Task.Delay(SuggestionCloseDelayMilliseconds, closeCts.Token);
            if (!ReferenceEquals(_suggestionCloseCts, closeCts))
            {
                return;
            }

            IsSuggestionPanelOpen = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) when (closeCts.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_suggestionCloseCts, closeCts))
            {
                _suggestionCloseCts = null;
            }

            closeCts.Dispose();
        }
    }

    private void CloseSuggestionPanel()
    {
        CancelPendingSuggestionClose();
        IsSuggestionPanelOpen = false;
    }

    private void CancelPendingSuggestionClose()
    {
        _suggestionCloseCts?.Cancel();
        _suggestionCloseCts = null;
    }

    private void CancelPendingSearchRefresh(bool clearBusyState)
    {
        _searchRefreshVersion++;
        _searchDebounceCts?.Cancel();
        _searchDebounceCts = null;

        if (clearBusyState)
        {
            IsSearchRefreshing = false;
        }
    }

    private SearchAssistViewModel BuildSearchAssist()
    {
        if (IsSearchRefreshing)
        {
            return new SearchAssistViewModel(
                "Buscando agora",
                $"Atualizando resultados e sugestoes para \"{SearchText}\".",
                "loading");
        }

        if (string.IsNullOrWhiteSpace(SearchText))
        {
            return new SearchAssistViewModel(
                "Busca instantanea",
                "Digite marca, linha ou chipset para ver sugestoes enquanto a lista filtra ao vivo.",
                "neutral");
        }

        if (Suggestions.Count == 0)
        {
            return new SearchAssistViewModel(
                "Sem sugestao imediata",
                "Tente marca, linha ou chipset. A cobertura ampla continua procurando modelos recentes.",
                "neutral");
        }

        if (FullSuggestionCount > 0 && (PartialSuggestionCount > 0 || CoverageSuggestionCount > 0))
        {
            return new SearchAssistViewModel(
                $"{Suggestions.Count} sugestoes encontradas",
                $"{FullSuggestionCount} com ficha pronta, {PartialSuggestionCount} parcial(is) e {CoverageSuggestionCount} em cobertura inicial. Enter abre a melhor opcao pronta.",
                "good");
        }

        if (FullSuggestionCount > 0)
        {
            return new SearchAssistViewModel(
                $"{FullSuggestionCount} sugestoes prontas",
                "Toque em um modelo ou pressione Enter para abrir a melhor correspondencia.",
                "good");
        }

        if (PartialSuggestionCount > 0)
        {
            return new SearchAssistViewModel(
                $"{PartialSuggestionCount} ficha(s) parcial(is)",
                "Esses modelos ja tem parte da ficha publicada, mas ainda nao entram como promessa publica completa.",
                "warn");
        }

        return new SearchAssistViewModel(
            "Cobertura inicial encontrada",
            "Esses modelos ja aparecem na busca publica, mesmo antes da ficha tecnica completa.",
            "warn");
    }

    private PhoneSearchResult? BuildFeaturedMatch()
    {
        if (string.IsNullOrWhiteSpace(SearchText) || Phones.Count == 0)
        {
            return null;
        }

        return Phones
            .Where(phone => phone.IsPublicReady && IsExactSearchMatch(phone, SearchText))
            .Concat(Phones.Where(phone => phone.IsPartialCatalogEntry && IsExactSearchMatch(phone, SearchText)))
            .Concat(Phones.Where(phone => !phone.HasFullCatalogEntry && IsExactSearchMatch(phone, SearchText)))
            .Concat(Phones.Where(phone => phone.IsPublicReady && IsStrongSearchMatch(phone, SearchText)))
            .Concat(Phones.Where(phone => phone.IsPartialCatalogEntry && IsStrongSearchMatch(phone, SearchText)))
            .Concat(Phones.Where(phone => !phone.HasFullCatalogEntry && IsStrongSearchMatch(phone, SearchText)))
            .FirstOrDefault();
    }

    private IReadOnlyList<CatalogSectionViewModel> BuildSections(IReadOnlyList<PhoneSearchResult> phones)
    {
        if (!string.IsNullOrWhiteSpace(SearchText) || !string.IsNullOrWhiteSpace(SelectedTierKey) || !string.IsNullOrWhiteSpace(SelectedBrandSlug))
        {
            var fullEntries = phones.Where(phone => phone.IsPublicReady).ToList();
            var partialEntries = phones.Where(phone => phone.IsPartialCatalogEntry).ToList();
            var coverageEntries = phones.Where(phone => !phone.HasFullCatalogEntry).ToList();
            var filteredSections = new List<CatalogSectionViewModel>();
            var exactCoverageEntries = FindExactSearchMatches(coverageEntries, SearchText);
            var hasExactCatalogMatch = FindExactSearchMatches(fullEntries.Concat(partialEntries).ToList(), SearchText).Count > 0;
            var promoteCoverageExactMatch = exactCoverageEntries.Count > 0 && !hasExactCatalogMatch;
            var remainingCoverageEntries = promoteCoverageExactMatch
                ? coverageEntries.Where(phone => exactCoverageEntries.All(match => match.Id != phone.Id)).ToList()
                : coverageEntries;

            if (promoteCoverageExactMatch)
            {
                filteredSections.Add(new CatalogSectionViewModel(
                    "Correspondencia exata",
                    "O modelo digitado foi encontrado na cobertura ampla e aparece primeiro para nao ficar escondido atras de fichas relacionadas.",
                    exactCoverageEntries));
            }

            if (fullEntries.Count > 0)
            {
                filteredSections.Add(new CatalogSectionViewModel(
                    promoteCoverageExactMatch
                        ? "Fichas completas relacionadas"
                        : coverageEntries.Count > 0 ? "Fichas completas" : "Resultados encontrados",
                    promoteCoverageExactMatch
                        ? "Esses modelos ja estao prontos para comparar enquanto a ficha exata ainda termina de consolidar specs e fontes."
                        : coverageEntries.Count > 0
                            ? "Modelos com specs consolidadas, comparacao ativa e leitura pronta para decisao."
                            : "Tudo que bate com a busca atual aparece aqui, sem esconder a acao principal.",
                    fullEntries));
            }

            if (partialEntries.Count > 0)
            {
                filteredSections.Add(new CatalogSectionViewModel(
                    "Fichas parciais",
                    "Esses modelos ja exibem parte da ficha, mas ainda faltam campos essenciais ou imagem confiavel para serem tratados como promessa publica completa.",
                    partialEntries,
                    StartsCollapsed: fullEntries.Count > 0));
            }

            if (remainingCoverageEntries.Count > 0)
            {
                filteredSections.Add(new CatalogSectionViewModel(
                    promoteCoverageExactMatch ? "Mais cobertura inicial" : "Cobertura inicial",
                    promoteCoverageExactMatch
                        ? "Outros modelos encontrados na busca ampla, ainda aguardando consolidacao completa de specs e comparacao."
                        : "Modelos que ja entram na busca publica, mas ainda estao aguardando consolidacao completa de specs e comparacao.",
                    remainingCoverageEntries,
                    StartsCollapsed: fullEntries.Count > 0));
            }

            return filteredSections;
        }

        var sections = new List<CatalogSectionViewModel>
        {
            CreateSection("Top de linha", "Modelos com foco em camera, desempenho e acabamento premium.", phones.Where(phone => phone.IsPublicReady && phone.Tier == "Top de linha")),
            CreateSection("Intermediarios", "Aparelhos equilibrados para quem quer desempenho e custo mais controlado.", phones.Where(phone => phone.IsPublicReady && phone.Tier == "Intermediario")),
            CreateSection("Entrada", "Modelos acessiveis para uso diario, com leitura simples das limitacoes e pontos fortes.", phones.Where(phone => phone.IsPublicReady && phone.Tier == "Entrada")),
        };

        var partialSection = CreateSection(
            "Fichas parciais",
            "Modelos encontrados e parcialmente consolidados, mas ainda fora da faixa de confianca que queremos para uso publico sem ressalvas.",
            phones.Where(phone => phone.IsPartialCatalogEntry));

        if (partialSection.Count > 0)
        {
            sections.Add(partialSection with { StartsCollapsed = true });
        }

        return sections.Where(item => item.Count > 0).ToList();
    }

    private static CatalogSectionViewModel CreateSection(string title, string description, IEnumerable<PhoneSearchResult> phones)
    {
        return new CatalogSectionViewModel(title, description, phones.ToList());
    }

    private static string SectionKey(CatalogSectionViewModel section)
    {
        return SectionAnchor(section.Title);
    }

    private IReadOnlyList<ActiveFilterViewModel> BuildActiveFilters()
    {
        var filters = new List<ActiveFilterViewModel>();

        if (!string.IsNullOrWhiteSpace(SearchText))
        {
            filters.Add(new ActiveFilterViewModel("search", $"Busca: {SearchText}"));
        }

        if (!string.IsNullOrWhiteSpace(SelectedBrandSlug))
        {
            var brandLabel = BrandOptions.FirstOrDefault(option => option.Slug == SelectedBrandSlug)?.Name ?? SelectedBrandSlug;
            filters.Add(new ActiveFilterViewModel("brand", $"Marca: {brandLabel}"));
        }

        if (!string.IsNullOrWhiteSpace(SelectedTierKey))
        {
            var tierLabel = TierOptions.FirstOrDefault(option => option.Key == SelectedTierKey)?.Label ?? SelectedTierKey;
            filters.Add(new ActiveFilterViewModel("tier", $"Faixa: {tierLabel}"));
        }

        if (SelectedSortKey != "auto")
        {
            filters.Add(new ActiveFilterViewModel("sort", $"Ordem: {CurrentSortLabel}"));
        }

        return filters;
    }

    private static string NormalizeTierKey(string? tier)
    {
        return tier?.Trim().ToLowerInvariant() switch
        {
            "entrada" => "entrada",
            "intermediario" => "intermediario",
            "top" => "top",
            _ => "",
        };
    }

    private static string NormalizeBrandSlug(string? brand)
    {
        return brand?.Trim().ToLowerInvariant() ?? "";
    }

    private static string NormalizeSortKey(string? sort)
    {
        return sort?.Trim().ToLowerInvariant() switch
        {
            "newest" => "newest",
            "confidence" => "confidence",
            "name" => "name",
            _ => "auto",
        };
    }

    private static ClassificationTier? ParseTier(string? tier)
    {
        return NormalizeTierKey(tier) switch
        {
            "entrada" => ClassificationTier.Entry,
            "intermediario" => ClassificationTier.MidRange,
            "top" => ClassificationTier.Flagship,
            _ => null,
        };
    }

    private static CatalogSortOption ParseSort(string? sort, string? currentQuery)
    {
        return NormalizeSortKey(sort) switch
        {
            "newest" => CatalogSortOption.Newest,
            "confidence" => CatalogSortOption.Confidence,
            "name" => CatalogSortOption.Name,
            _ => string.IsNullOrWhiteSpace(currentQuery)
                ? CatalogSortOption.Newest
                : CatalogSortOption.Relevance,
        };
    }

    private static string FormatRelease(DateTimeOffset? releasedAt)
    {
        return releasedAt is null
            ? "Sem data publicada"
            : $"Lancado em {releasedAt.Value:MMM yyyy}";
    }

    private static string SuggestionMeta(PhoneSuggestionDto suggestion)
    {
        if (!suggestion.HasFullCatalogEntry)
        {
            return "Cobertura inicial · ficha completa em preparacao";
        }

        return string.IsNullOrWhiteSpace(suggestion.Chipset)
            ? suggestion.PrimaryBadgeLabel
            : $"{suggestion.PrimaryBadgeLabel} · {CompactChipset(suggestion.Chipset)}";
    }

    private static string PresetTitle(ComparisonQuickStartDto preset)
    {
