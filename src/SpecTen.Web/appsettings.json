{
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Scraping": {
    "Enabled": false,
    "UseFixtureAdapters": false,
    "DailyUtcHour": 6,
    "PerDomainDelayMilliseconds": 750,
    "UserAgent": "SpecTenBot/1.0"
  },
  "Coverage": {
    "Enabled": true,
    "DataUrl": "https://www.gsmarena.com/sitemaps/phones.xml",
    "SourceName": "GSMArena",
    "SourceUrl": "https://www.gsmarena.com/",
    "SnapshotFilePath": "Data/coverage-index.snapshot.json",
    "RefreshHours": 24,
    "MinimumQueryLength": 2,
    "OnDemandHydrationEnabled": true,
    "ExactHydrationLimit": 1,
    "MakerPageLimit": 24,
    "MakerPageDelayMilliseconds": 250,
    "CatalogEntryRefreshHours": 168
  },
  "CatalogSeed": {
    "Enabled": true,
    "FilePath": "Data/catalog-seed.json",
    "DataUrl": "",
    "DefaultSourceName": "Catalog seed",
    "DefaultSourceUrl": "",
    "DefaultPolicyStatus": "ManualFeed",
    "RobotsAllowed": true,
    "IsOfficialSource": false
  },
  "PublicApi": {
    "RateLimitPermitLimit": 120,
    "RateLimitWindowSeconds": 60,
    "SearchCacheSeconds": 20,
    "SuggestionCacheSeconds": 10,
    "PhoneCacheSeconds": 120,
    "CompareCacheSeconds": 30,
    "SitemapCacheSeconds": 900,
    "RobotsCacheSeconds": 3600
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "System.Net.Http.HttpClient.device-coverage": "Warning"
    }
  },
  "AllowedHosts": "*"
}
