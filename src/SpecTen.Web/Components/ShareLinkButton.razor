@inject IJSRuntime JS

<div class="share-link">
    <button class="button subtle compact"
            type="button"
            disabled="@IsBusy"
            @onclick="ShareAsync">
        @ButtonLabel
    </button>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <span class="share-link-status">@StatusMessage</span>
    }
</div>

@code {
    [Parameter]
    public string Url { get; set; } = "/";

    [Parameter]
    public string Title { get; set; } = "SpecTen";

    [Parameter]
    public string? Text { get; set; }

    private bool IsBusy { get; set; }
    private string? StatusMessage { get; set; }

    private string ButtonLabel => IsBusy ? "Compartilhando..." : "Compartilhar";

    private async Task ShareAsync()
    {
        IsBusy = true;
        StatusMessage = null;

        try
        {
            var result = await JS.InvokeAsync<string>(
                "spectenShare.shareOrCopy",
                Url,
                Title,
                Text);

            StatusMessage = result switch
            {
                "shared" => "Compartilhado",
                "copied" => "Link copiado",
                _ => null,
            };
        }
        catch
        {
            StatusMessage = "Nao foi possivel compartilhar agora";
        }
        finally
        {
            IsBusy = false;
        }
    }
}
