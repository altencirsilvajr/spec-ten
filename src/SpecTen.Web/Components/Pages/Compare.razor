    private async Task UpdateComparisonAsync(string title, string message, Func<Task> update)
    {
        IsComparisonUpdating = true;
        ComparisonOperationTitle = title;
        ComparisonOperationMessage = message;
        await InvokeAsync(StateHasChanged);

        try
        {
            await update();
        }
        finally
        {
            IsComparisonUpdating = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleBuilder()
    {
        IsBuilderExpanded = !IsBuilderExpanded;
    }

    private void CollapseBuilder()
    {
        IsBuilderExpanded = false;
    }

    private async Task QueueSearchRefreshAsync()
    {
        CancelPendingSearchRefresh(clearBusyState: false);
        if (string.IsNullOrWhiteSpace(SearchText))
        {
            Suggestions = [];
            ActiveSuggestionIndex = -1;
            IsSearchRefreshing = false;
            return;
        }

        var debounceCts = new CancellationTokenSource();
        _searchDebounceCts = debounceCts;
        IsSearchRefreshing = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(SearchDebounceMilliseconds, debounceCts.Token);
            await RefreshSuggestionsAsync(debounceCts.Token);
        }
        catch (OperationCanceledException) when (debounceCts.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_searchDebounceCts, debounceCts))
            {
                _searchDebounceCts = null;
                IsSearchRefreshing = false;
                await InvokeAsync(StateHasChanged);
            }

            debounceCts.Dispose();
        }
    }

    private async Task RefreshSuggestionsAsync(CancellationToken cancellationToken)
    {
        Suggestions = string.IsNullOrWhiteSpace(SearchText)
            ? []
            : await Catalog.SuggestForLiveDiscoveryAsync(SearchText, 8, cancellationToken);
        ResetSuggestionSelection();
    }

    private async Task ActivateActiveSuggestionAsync()
    {
        if (ActiveSuggestionIndex < 0 || ActiveSuggestionIndex >= SuggestionOptions.Count)
        {
            return;
        }

        await ActivateSuggestionAsync(SuggestionOptions[ActiveSuggestionIndex]);
    }

    private async Task ActivateSuggestionAsync(CompareSuggestionOption option)
    {
        if (IsComparisonUpdating)
        {
            return;
        }

        CancelPendingSearchRefresh(clearBusyState: true);
        if (option.Suggestion.IsPublicReady)
        {
            await AddSuggestionAsync(option.Suggestion);
            return;
        }

        if (SelectedIds.Count >= 4)
        {
            return;
        }

        var shouldOpenDetails = false;
        await UpdateComparisonAsync(
            "Carregando ficha para comparar",
            $"Buscando as especificacoes de {option.Suggestion.FullName}. Isso pode levar alguns segundos.",
            async () =>
            {
                var hydratedPhone = await Catalog.GetPhoneBySlugAsync(option.Suggestion.BrandSlug, option.Suggestion.Slug, CancellationToken.None);
                if (hydratedPhone is not null && hydratedPhone.IsPublicReady && !SelectedIds.Contains(hydratedPhone.Id))
                {
                    SelectedIds.Add(hydratedPhone.Id);
                    SearchText = "";
                    Suggestions = [];
                    ActiveSuggestionIndex = -1;
                    CloseSuggestionPanel();
                    await LoadComparisonAsync();
                    Navigation.NavigateTo(BuildCompareUrl(), replace: true);
                    return;
                }

                Suggestions = [];
                ActiveSuggestionIndex = -1;
                CloseSuggestionPanel();
                shouldOpenDetails = true;
            });

        if (shouldOpenDetails)
        {
            Navigation.NavigateTo($"/celulares/{option.Suggestion.BrandSlug}/{option.Suggestion.Slug}");
        }
    }

    private void MoveActiveSuggestion(int step)
    {
        if (SuggestionOptions.Count == 0)
        {
            ActiveSuggestionIndex = -1;
            return;
        }

        ActiveSuggestionIndex = ActiveSuggestionIndex < 0
            ? 0
            : (ActiveSuggestionIndex + step + SuggestionOptions.Count) % SuggestionOptions.Count;
    }

    private void ResetSuggestionSelection()
    {
        ActiveSuggestionIndex = SuggestionOptions.Count > 0 ? 0 : -1;
    }

    private void OpenSuggestionPanel()
    {
        CancelPendingSuggestionClose();
        IsSuggestionPanelOpen = true;
    }

    private async Task CloseSuggestionPanelAfterDelayAsync()
    {
        CancelPendingSuggestionClose();
        var closeCts = new CancellationTokenSource();
        _suggestionCloseCts = closeCts;

        try
        {
            await Task.Delay(SuggestionCloseDelayMilliseconds, closeCts.Token);
            if (!ReferenceEquals(_suggestionCloseCts, closeCts))
            {
                return;
            }

            IsSuggestionPanelOpen = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) when (closeCts.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_suggestionCloseCts, closeCts))
            {
                _suggestionCloseCts = null;
            }

            closeCts.Dispose();
        }
    }

    private void CloseSuggestionPanel()
    {
        CancelPendingSuggestionClose();
        IsSuggestionPanelOpen = false;
    }

    private void CancelPendingSuggestionClose()
    {
        _suggestionCloseCts?.Cancel();
        _suggestionCloseCts = null;
    }

    private void CancelPendingSearchRefresh(bool clearBusyState)
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts = null;

        if (clearBusyState)
        {
            IsSearchRefreshing = false;
        }
    }

    private SearchAssistViewModel BuildSearchAssist()
    {
        if (IsSearchRefreshing)
        {
            return new SearchAssistViewModel(
                "Buscando modelos",
                $"Separando o que pode entrar agora na comparacao para \"{SearchText}\".",
                "loading");
        }

        if (string.IsNullOrWhiteSpace(SearchText))
        {
            return new SearchAssistViewModel(
                "Adicao guiada",
                "Digite o modelo para ver o que entra na comparacao na hora. Quando a ficha ainda nao estiver localmente pronta, tentamos completar tudo durante a selecao.",
                "neutral");
        }

        if (FullSuggestionCount == 0 && CoverageSuggestionCount == 0)
        {
            return new SearchAssistViewModel(
                "Nenhum modelo encontrado",
                "Tente a marca e a linha do aparelho. A comparacao aceita apenas fichas tecnicas ja publicadas.",
                "neutral");
        }

        if (FullSuggestionCount > 0 && (PartialSuggestionCount > 0 || CoverageSuggestionCount > 0))
        {
            return new SearchAssistViewModel(
                $"{FullSuggestionCount} modelos prontos, {PartialSuggestionCount} parcial(is) e {CoverageSuggestionCount} em cobertura inicial",
                "Os prontos entram agora. Os demais abrem a ficha para consolidacao antes de voltarem ao comparador.",
                "good");
        }

        if (FullSuggestionCount > 0)
        {
            return new SearchAssistViewModel(
                $"{FullSuggestionCount} modelos prontos para comparar",
                "Toque em uma sugestao e ela entra na comparacao imediatamente.",
                "good");
        }

        if (PartialSuggestionCount > 0)
        {
            return new SearchAssistViewModel(
                $"{PartialSuggestionCount} ficha(s) parcial(is)",
                "Esses modelos ja tem parte da ficha publicada, mas ainda nao entram no comparador publico sem revisao extra.",
                "warn");
        }

        return new SearchAssistViewModel(
            CoverageSuggestionCount == 1 ? "Ficha sob demanda encontrada" : $"{CoverageSuggestionCount} fichas sob demanda",
            "Selecione o modelo para puxar a ficha completa e liberar a comparacao.",
            "warn");
    }

    private async Task LoadComparisonAsync()
    {
        var comparisonWasReady = CanRenderComparisonTable;
        Comparison = await Catalog.CompareAsync(SelectedIds, CancellationToken.None);
        SelectedIds = Comparison.Phones
            .Select(phone => phone.Id)
            .ToList();
        SyncCompareSelection();
        if (Comparison.Phones.Count < 2)
        {
            OnlyDifferences = false;
            IsBuilderExpanded = true;
        }
        else if (!comparisonWasReady)
        {
            IsBuilderExpanded = false;
        }

        EnsureSelectedGroupFilterIsVisible();
        PruneMobileSectionState();
    }

    private string BuildCompareUrl()
    {
        return SelectedIds.Count == 0
            ? "/comparar"
            : $"/comparar?ids={string.Join(",", SelectedIds)}";
    }

    private void SyncCompareSelection()
    {
        CompareSelection.Replace(Comparison.Phones.Select(ToCompareSelectionItem));
    }

    private static IEnumerable<SpecFactDto> QuickSpecs(PhoneDetailsDto phone)
    {
        return phone.SpecGroups
            .SelectMany(group => group.Specs)
            .Where(spec => spec.Key is "chipset" or "display_size" or "main_camera" or "battery")
            .Take(4);
    }

    private static string QuickSpecValue(SpecFactDto spec)
    {
        return spec.Key == "chipset"
            ? PhoneNameFormatter.CompactChipset(spec.DisplayValue)
            : spec.DisplayValue;
    }

    private static string FormatRelease(DateTimeOffset? releasedAt)
    {
        return releasedAt is null
            ? "Sem data publicada"
            : $"Lancado em {releasedAt.Value:dd/MM/yyyy}";
    }

    private static string FormatLaunchPrice(decimal? launchPriceUsd)
    {
        return launchPriceUsd is null
            ? "Preco nao publicado"
            : $"US$ {launchPriceUsd.Value:0} no lancamento";
