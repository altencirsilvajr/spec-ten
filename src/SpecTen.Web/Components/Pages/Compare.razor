@page "/comparar"
@rendermode InteractiveServer
@implements IDisposable
@inject CatalogService Catalog
@inject CompareSelectionState CompareSelection
@inject NavigationManager Navigation

<PageTitle>Comparar celulares</PageTitle>
<HeadContent>
    <meta name="description" content="Comparacao lado a lado de celulares com filtros por grupo, destaque de diferencas e leitura pronta para mobile." />
    <meta property="og:title" content="Comparar celulares" />
    <meta property="og:description" content="Monte uma comparacao com dois a quatro celulares e veja as diferencas sem esconder a ficha tecnica." />
    <link rel="canonical" href="@CurrentCompareUrl" />
</HeadContent>

<section class="section-heading compare-heading tool-heading @(CanRenderComparisonTable ? "compact" : null)">
    <div>
        <p class="eyebrow">Comparador</p>
        <h1 class="page-title">Comparacao lado a lado sem esconder metade da ficha.</h1>
        <p class="page-lede">A tabela usa todas as specs publicadas, permite trocar modelos sem sair da pagina e deixa claro quando ainda falta aparelho para comparar.</p>
    </div>
    <div class="heading-actions">
        <ShareLinkButton Url="@CurrentCompareUrl"
                         Title="Comparacao de celulares"
                         Text="Compare estes modelos lado a lado no SpecTen." />
        <a class="button subtle" href="/celulares">Voltar ao catalogo</a>
    </div>
</section>

@if (IsComparisonUpdating)
{
    <section class="operation-status compare-operation-status" role="status" aria-live="assertive">
        <span class="loading-spinner" aria-hidden="true"></span>
        <div>
            <strong>@ComparisonOperationTitle</strong>
            <span>@ComparisonOperationMessage</span>
        </div>
    </section>
}

@if (CanRenderComparisonTable)
{
    <section class="compare-ready-bar" aria-label="Comparacao pronta" aria-busy="@IsComparisonBusy">
        <div class="compare-ready-copy">
            <strong>@Comparison.Phones.Count modelos prontos</strong>
            <span>@VisibleRows.Count specs visiveis no recorte atual</span>
        </div>
        <div class="compare-ready-actions">
            <button class="button subtle compact" type="button" disabled="@IsComparisonUpdating" @onclick="ToggleBuilder">
                @(IsBuilderExpanded ? "Fechar edicao" : "Trocar modelos")
            </button>
            <a class="button primary compact" href="#compare-results-shell">Ir para tabela</a>
        </div>
    </section>
}

@if (!CanRenderComparisonTable || IsBuilderExpanded)
{
    <section class="compare-builder" aria-busy="@IsComparisonBusy">
        <div class="toolbar-search">
            <label for="compare-search">Buscar e adicionar modelos</label>
            <div class="search-input-shell">
                <input id="compare-search"
                       value="@SearchText"
                       @oninput="OnSearchChanged"
                       @onfocus="OnSearchFocused"
                       @onblur="OnSearchBlur"
                       @onkeydown="OnSearchKeyDown"
                       autocomplete="off"
                       autocapitalize="off"
                       autocorrect="off"
                       spellcheck="false"
                       inputmode="search"
                       role="combobox"
                       aria-autocomplete="list"
                       aria-expanded="@(HasSuggestions ? "true" : "false")"
                       aria-controls="compare-suggestions"
                       aria-activedescendant="@ActiveSuggestionId"
                       disabled="@IsComparisonUpdating"
                       placeholder="Ex.: Xiaomi 15T Pro, Galaxy A56, iPhone 16 Pro..." />
                <button class="button subtle" type="button" @onclick="ClearSelection" disabled="@(Comparison.Phones.Count == 0 || IsComparisonUpdating)">Limpar comparacao</button>
            </div>

            <div class="search-assist-strip @SearchAssistTone" role="status" aria-live="polite">
                <strong>@SearchAssistTitle</strong>
                <span>@SearchAssistMessage</span>
            </div>

            @if (HasSuggestions)
            {
                <div id="compare-suggestions" class="suggestion-panel" role="listbox" aria-label="Sugestoes para comparacao">
                    @for (var index = 0; index < SuggestionOptions.Count; index++)
                    {
                        var option = SuggestionOptions[index];
                        var suggestion = option.Suggestion;
                        var limitReached = SelectedIds.Count >= 4;
                        var isActive = ActiveSuggestionIndex == index;
                        <button class="suggestion-item @(option.IsPending ? "pending" : null) @(isActive ? "active" : null)"
                                id="@SuggestionId(index)"
                                role="option"
                                aria-selected="@isActive"
                                type="button"
                                disabled="@(limitReached || IsComparisonUpdating)"
                                @onclick="() => ActivateSuggestionAsync(option)">
                            <span class="suggestion-title">@suggestion.FullName</span>
                            <span class="suggestion-meta">
                                @if (suggestion.IsPublicReady)
                                {
                                    @suggestion.PrimaryBadgeLabel
                                    @if (!string.IsNullOrWhiteSpace(suggestion.Chipset))
                                    {
                                        <text> · @PhoneNameFormatter.CompactChipset(suggestion.Chipset)</text>
                                    }

                                    @if (limitReached)
                                    {
                                        <text> · limite de 4</text>
                                    }
                                }
                                else
                                {
                                    <text>@(suggestion.IsPartialCatalogEntry ? "Abrir ficha parcial" : "Carregar ficha completa e adicionar")</text>
                                }
                            </span>
                        </button>
                    }
                </div>
            }
        </div>

        <div class="compare-builder-status" aria-live="polite">
            <strong>@Comparison.Phones.Count de 4 modelos na comparacao</strong>
            <span>@BuilderHint</span>

            <div class="builder-action-row">
                @if (CanRenderComparisonTable)
                {
                    <button class="button subtle compact" type="button" @onclick="CollapseBuilder">Voltar para as specs</button>
                }
                else
                {
                    <a class="button subtle compact" href="/celulares">Buscar mais modelos no catalogo</a>
                }
            </div>

            @if (Comparison.Phones.Count > 0)
            {
                <div class="selected-chip-list">
                    @foreach (var phone in Comparison.Phones)
                    {
                        <button class="selected-chip" type="button" disabled="@IsComparisonUpdating" @onclick="() => RemovePhoneAsync(phone.Id)">
                            <span>@phone.FullName</span>
                            <span aria-hidden="true">x</span>
                        </button>
                    }
                </div>
            }
        </div>
    </section>
}

@if (Comparison.Phones.Count < 2 && VisibleQuickStartPhones.Count > 0 && string.IsNullOrWhiteSpace(SearchText))
{
    <section class="quick-start-panel" aria-label="Sugestoes rapidas para comparacao">
        <strong>Sugestoes rapidas para comecar</strong>
        <p class="muted">Modelos recentes com ficha completa que entram na comparacao com um toque, sem obrigar o usuario a adivinhar o nome exato.</p>
        <div class="selected-chip-list">
            @foreach (var phone in VisibleQuickStartPhones)
            {
                <button class="jump-chip quick-start-chip"
                        type="button"
                        disabled="@IsComparisonUpdating"
                        @onclick="() => AddQuickStartPhoneAsync(phone)">
                    <span>@phone.FullName</span>
                    <span>@phone.Tier</span>
                </button>
            }
        </div>
    </section>
}

@if (Comparison.Phones.Count == 0)
{
    <section class="empty-state">
        <h2>Nenhum aparelho selecionado</h2>
        <p class="muted">Comece buscando um modelo acima ou use as sugestoes rapidas logo antes deste aviso. O comparador aceita de dois a quatro aparelhos por vez.</p>
        <a class="button primary" href="/celulares">Voltar ao catalogo</a>
    </section>
}
else
{
    <section class="compare-toolbar">
        <label class="toggle-line">
            <input type="checkbox" @bind="OnlyDifferences" disabled="@(!CanRenderComparisonTable)" />
            <span>Mostrar so diferencas</span>
        </label>

        <div class="compare-toolbar-copy">
            <strong>@Comparison.Phones.Count modelos</strong>
            <span>@VisibleRows.Count specs visiveis</span>
        </div>
    </section>

    @if (CanRenderComparisonTable)
    {
        <section class="table-filter-bar" aria-label="Filtrar specs da comparacao">
            <div class="table-filter-search">
                <label for="compare-row-filter">Filtrar specs visiveis</label>
                <div class="search-row">
                    <input id="compare-row-filter"
                           value="@TableFilterText"
                           @oninput="OnTableFilterChanged"
                           placeholder="Camera, carregamento, IP68, peso..." />
                    <button class="button subtle compact"
                            type="button"
                            disabled="@(!HasActiveTableFilters)"
                            @onclick="ClearTableFilters">
                        Limpar filtro
                    </button>
                </div>
                <p class="muted">Busque por nome da spec, grupo ou valor para cortar ruido na leitura mobile sem esconder as linhas importantes.</p>
            </div>

            @if (CompareGroupFilters.Count > 1)
            {
                <div class="table-filter-groups">
                    <span class="jumpbar-label">Grupos da tabela</span>
                    <div class="jumpbar-list">
                        @foreach (var groupFilter in CompareGroupFilters)
                        {
                            <button class="jump-chip @(SelectedGroupFilter == groupFilter.Key ? "active" : null)"
                                    type="button"
                                    aria-pressed="@(SelectedGroupFilter == groupFilter.Key)"
                                    @onclick="() => SetGroupFilter(groupFilter.Key)">
                                <span>@groupFilter.Label</span>
                                <span>@groupFilter.Count</span>
                            </button>
                        }
                    </div>
                </div>
            }
        </section>
    }

    @if (CanRenderComparisonTable && HasVisibleRows && ComparisonHighlights.Count > 0)
    {
        <section class="compare-highlights" aria-label="Destaques da comparacao">
            <div class="highlight-heading">
                <strong>Destaques da comparacao</strong>
                <span class="muted">Leitura rapida das diferencas mais importantes antes de entrar na tabela.</span>
            </div>
            @foreach (var highlight in ComparisonHighlights)
            {
                <article class="highlight-card @(highlight.WinnerPhoneId is not null ? "winner" : "neutral")">
                    <span class="eyebrow">@highlight.Title</span>
                    <strong>@highlight.LeadingLabel</strong>
                    <p>@highlight.Description</p>
                    <span class="muted">@highlight.ValueSummary</span>
                </article>
            }
        </section>
    }

    @if (CanRenderComparisonTable && HasVisibleRows && VisibleSections.Count > 1)
    {
        <nav class="section-jumpbar compare-jumpbar" aria-label="Ir para grupo da comparacao">
            <strong class="jumpbar-label">Ir para grupo</strong>
            <div class="jumpbar-list">
                @foreach (var groupLink in VisibleSections)
                {
                    <a class="jump-chip" href="@($"#{SectionAnchor(groupLink.Name)}")">
                        <span>@groupLink.Name</span>
                        <span>@groupLink.Rows.Count</span>
                    </a>
                }
            </div>
        </nav>
    }

    @if (CanRenderComparisonTable && HasVisibleRows)
    {
        <section class="comparison-insights" aria-label="Resumo da comparacao">
            @foreach (var phone in Comparison.Phones)
            {
                <article class="insight-card @(TopWinnerId == phone.Id ? "top" : null)">
                    <span class="muted">@phone.FullName</span>
                    <strong class="insight-metric">@WinnerCount(phone.Id)</strong>
                    <p>vitoria(s) automatica(s) em specs numericas comparaveis</p>
                    <span class="muted">@MissingCount(phone.Id) campo(s) ausente(s)</span>
                </article>
            }

            <article class="insight-card neutral">
                <span class="muted">Leitura rapida</span>
                <strong class="insight-metric">@TieCount</strong>
                <p>spec(s) empatada(s) entre os modelos atuais</p>
                <span class="muted">@RowsWithMissingValues linha(s) com lacunas visiveis</span>
            </article>
        </section>
    }

    <div class="phone-grid compare-phone-grid">
        @foreach (var phone in Comparison.Phones)
        {
            <article class="phone-card compare-phone-card">
                <div class="phone-card-media media-frame">
                    <PhoneMediaContent ImageUrl="@phone.ImageUrl"
                                       Alt="@phone.FullName"
                                       Brand="@phone.DisplayBrand"
                                       Model="@phone.ModelName" />
                </div>

                <div class="phone-card-body">
                    <div class="catalog-card-header">
                        <div>
                            <p class="muted">@phone.DisplayBrand</p>
                            <h2><a href="/celulares/@phone.BrandSlug/@phone.Slug">@phone.ModelName</a></h2>
                            <p class="catalog-meta">@phone.TrustLabel · confianca minima: @phone.MinConfidence.ToString("P0")</p>
                            <div class="compare-card-meta">
                                <span>@FormatRelease(phone.ReleasedAt)</span>
                                @if (phone.LaunchPriceUsd is not null)
                                {
                                    <span>@FormatLaunchPrice(phone.LaunchPriceUsd)</span>
                                }
                                <span>@FreshnessFormatter.UpdatedLabel(phone.UpdatedAt)</span>
                            </div>
                            <p class="coverage-meta">Cobertura na tabela: @AvailableSpecCount(phone.Id)/@Comparison.Rows.Count specs</p>
                        </div>
                        <span class="tier">@phone.Classification.Label</span>
                    </div>

                    <div class="coverage-meter" aria-label="Cobertura de specs na comparacao">
                        <span style="@($"width:{CoveragePercent(phone.Id)}%")"></span>
                    </div>

                    <dl class="spec-pills catalog-spec-pills">
                        @foreach (var spec in QuickSpecs(phone))
                        {
                            <div>
                                <dt>@spec.DisplayName</dt>
                                <dd>@QuickSpecValue(spec)</dd>
                            </div>
                        }
                    </dl>

                    <div class="card-actions">
                        <a class="button subtle" href="/celulares/@phone.BrandSlug/@phone.Slug">Abrir ficha completa</a>
                        <button class="button subtle" type="button" disabled="@IsComparisonUpdating" @onclick="() => RemovePhoneAsync(phone.Id)">Remover</button>
                    </div>
                </div>
            </article>
        }
    </div>

    @if (!CanRenderComparisonTable)
    {
        <p class="notice">Adicione pelo menos mais um modelo para destacar diferencas e vencedores por categoria.</p>
    }
    else if (!HasVisibleRows)
    {
        <p class="notice warn">@EmptyVisibleRowsMessage</p>
    }
    else
    {
        @if (HasMissingSpecs)
        {
            <p class="notice warn">Algumas celulas ainda nao tem o mesmo nivel de cobertura. Valores ausentes continuam visiveis para nao mascarar lacunas.</p>
        }

        @if (CanRenderComparisonTable && HasVisibleRows && VisibleSections.Count > 1)
        {
            <section class="mobile-section-toolbar" aria-label="Controles mobile da comparacao">
                <div class="mobile-section-toolbar-copy">
                    <strong>Leitura mobile por grupo</strong>
                    <span>@ExpandedMobileSectionCount de @VisibleSections.Count grupo(s) abertos</span>
                </div>
                <div class="mobile-section-toolbar-actions">
                    <button class="jump-chip" type="button" @onclick="ExpandAllMobileSections">Abrir todos</button>
                    <button class="jump-chip" type="button" @onclick="RestoreEssentialMobileSections">Ver essenciais</button>
                </div>
            </section>
        }

        <div id="compare-results-shell" class="compare-results-shell">
            <div class="compare-mobile-stack" aria-label="Comparacao em blocos para celular">
                @foreach (var groupSection in VisibleSections)
                {
                    var isExpanded = IsMobileSectionExpanded(groupSection);
                    <section id="@SectionAnchor(groupSection.Name)" class="mobile-spec-group @(isExpanded ? "expanded" : "collapsed")">
                        <button class="mobile-spec-group-toggle"
                                type="button"
                                aria-expanded="@isExpanded"
                                @onclick="() => ToggleMobileSection(groupSection)">
                            <div class="mobile-spec-group-heading">
                                <strong>@groupSection.Name</strong>
                                <span>@groupSection.Rows.Count spec(s)</span>
                            </div>
                            <span class="mobile-spec-group-state">@(isExpanded ? "Recolher" : "Abrir grupo")</span>
                        </button>

                        @if (isExpanded)
                        {
                            <div class="mobile-spec-grid">
                                @foreach (var row in groupSection.Rows)
                                {
                                    <article class="mobile-spec-card">
                                        <div class="mobile-spec-card-header">
                                            <strong>@row.DisplayName</strong>
                                        </div>

                                        <div class="mobile-spec-values">
                                            @foreach (var phone in Comparison.Phones)
                                            {
                                                var value = row.Values.GetValueOrDefault(phone.Id, "-");
                                                var isMissing = value == "-";
                                                <div class="mobile-spec-value @CellClass(row, phone.Id, isMissing)">
                                                    <span class="mobile-spec-phone">@phone.FullName</span>
                                                    <strong>@MobileCompareValue(value)</strong>
                                                </div>
                                            }
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="mobile-spec-collapsed-note">Abra este grupo para ver @groupSection.Rows.Count spec(s) sem perder a posicao da leitura.</p>
                        }
                    </section>
                }
            </div>

            <div id="compare-table-shell" class="compare-shell">
                <table class="compare-table">
                    <thead>
                        <tr>
                            <th>Spec</th>
                            @foreach (var phone in Comparison.Phones)
                            {
                                <th>
                                    <a href="/celulares/@phone.BrandSlug/@phone.Slug">@phone.FullName</a>
                                    <span>@phone.Classification.Label</span>
                                </th>
                            }
                        </tr>
                    </thead>
                    @foreach (var groupSection in VisibleSections)
                    {
                        <tbody id="@SectionAnchor(groupSection.Name)">
                            <tr class="compare-group-row">
                                <th colspan="@(Comparison.Phones.Count + 1)">@groupSection.Name</th>
                            </tr>

                            @foreach (var row in groupSection.Rows)
                            {
                                <tr>
                                    <th>
                                        <strong>@row.DisplayName</strong>
                                    </th>
                                    @foreach (var phone in Comparison.Phones)
                                    {
                                        var value = row.Values.GetValueOrDefault(phone.Id, "-");
                                        var isMissing = value == "-";
                                        <td class="@CellClass(row, phone.Id, isMissing)">
                                            @value
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    }
                </table>
            </div>
        </div>
    }
}

@code {
    [SupplyParameterFromQuery(Name = "ids")]
    public string[]? Ids { get; set; }

    private const int SearchDebounceMilliseconds = 180;
    private const int SuggestionCloseDelayMilliseconds = 120;
    private CompareResultDto Comparison { get; set; } = new([], []);
    private IReadOnlyList<PhoneSearchResult> QuickStartPhones { get; set; } = [];
    private IReadOnlyList<PhoneSuggestionDto> Suggestions { get; set; } = [];
    private List<int> SelectedIds { get; set; } = [];
    private string SearchText { get; set; } = "";
    private string TableFilterText { get; set; } = "";
    private string SelectedGroupFilter { get; set; } = "";
    private bool OnlyDifferences { get; set; }
    private int ActiveSuggestionIndex { get; set; } = -1;
    private bool IsSearchRefreshing { get; set; }
    private bool IsComparisonUpdating { get; set; }
    private string ComparisonOperationTitle { get; set; } = "Atualizando comparacao";
    private string ComparisonOperationMessage { get; set; } = "Organizando as fichas selecionadas. Aguarde um instante.";
    private bool HasRequestedIds { get; set; }
    private CancellationTokenSource? _searchDebounceCts;
    private CancellationTokenSource? _suggestionCloseCts;
    private bool IsSuggestionPanelOpen { get; set; }
    private bool IsBuilderExpanded { get; set; } = true;
    private Dictionary<string, bool> MobileSectionExpanded { get; } = new(StringComparer.Ordinal);

    private IReadOnlyList<CompareRowDto> SearchMatchedRows => BuildSearchMatchedRows();
    private IReadOnlyList<CompareRowDto> GroupMatchedRows => BuildGroupMatchedRows();
    private IReadOnlyList<CompareRowDto> VisibleRows => BuildVisibleRows();

    private IReadOnlyList<CompareSectionViewModel> VisibleSections => VisibleRows
        .GroupBy(row => row.Group)
        .Select(group => new CompareSectionViewModel(group.Key, group.ToList()))
        .ToList();
    private IReadOnlyList<CompareHighlightViewModel> ComparisonHighlights => BuildComparisonHighlights(VisibleRows);

    private bool CanRenderComparisonTable => Comparison.Phones.Count >= 2;
    private bool IsComparisonBusy => IsSearchRefreshing || IsComparisonUpdating;
    private bool HasVisibleRows => VisibleRows.Count > 0;
    private bool HasMissingSpecs => VisibleRows.Any(row => row.Values.Values.Contains("-", StringComparer.OrdinalIgnoreCase));
    private bool HasSuggestions => IsSuggestionPanelOpen && SuggestionOptions.Count > 0;
    private IReadOnlyList<PhoneSuggestionDto> SelectableSuggestions => Suggestions
        .Where(item => item.IsPublicReady && !SelectedIds.Contains(item.Id))
        .Take(6)
        .ToList();
    private IReadOnlyList<PhoneSuggestionDto> PendingSuggestions => Suggestions
        .Where(item => !item.IsPublicReady)
        .Take(4)
        .ToList();
    private IReadOnlyList<CompareSuggestionOption> SuggestionOptions => SelectableSuggestions
        .Select(item => new CompareSuggestionOption(item, false))
        .Concat(PendingSuggestions.Select(item => new CompareSuggestionOption(item, true)))
        .ToList();
    private IReadOnlyList<PhoneSearchResult> VisibleQuickStartPhones => QuickStartPhones
        .Where(phone => phone.IsPublicReady && !SelectedIds.Contains(phone.Id))
        .Take(6)
        .ToList();
    private IReadOnlyList<CompareGroupFilterViewModel> CompareGroupFilters => BuildCompareGroupFilters();
    private string? ActiveSuggestionId => ActiveSuggestionIndex >= 0 ? SuggestionId(ActiveSuggestionIndex) : null;
    private int FullSuggestionCount => SelectableSuggestions.Count;
    private int PartialSuggestionCount => PendingSuggestions.Count(item => item.IsPartialCatalogEntry);
    private int CoverageSuggestionCount => PendingSuggestions.Count(item => !item.HasFullCatalogEntry);
    private bool HasActiveTableFilters => !string.IsNullOrWhiteSpace(TableFilterText) || !string.IsNullOrWhiteSpace(SelectedGroupFilter);
    private int TieCount => VisibleRows.Count(row => row.WinnerPhoneId is null && RowHasExactTie(row));
    private int RowsWithMissingValues => VisibleRows.Count(row => row.Values.Values.Contains("-", StringComparer.OrdinalIgnoreCase));
    private int? TopWinnerId => ResolveTopWinnerId();
    private SearchAssistViewModel SearchAssist => BuildSearchAssist();
    private string SearchAssistTitle => SearchAssist.Title;
    private string SearchAssistMessage => SearchAssist.Message;
    private string SearchAssistTone => SearchAssist.Tone;
    private IReadOnlyList<CompareRowDto> CoverageRows => HasVisibleRows ? VisibleRows : Comparison.Rows;
    private string BuilderHint => Comparison.Phones.Count switch
    {
        0 => "Escolha o primeiro modelo para montar a comparacao.",
        1 => "Agora adicione mais um aparelho para ver as diferencas lado a lado.",
        4 => "Limite atingido. Remova um modelo para testar outra combinacao.",
        _ => "Voce pode manter ate quatro aparelhos na mesma analise.",
    };
    private string CurrentCompareUrl => BuildCompareUrl();
    private int ExpandedMobileSectionCount => VisibleSections.Count(IsMobileSectionExpanded);
    private string EmptyVisibleRowsMessage => OnlyDifferences && GroupMatchedRows.Count > 0
        ? "Com os filtros atuais, as specs restantes sao iguais entre os modelos. Desative 'Mostrar so diferencas' para ver todas."
        : "Nenhuma spec combina com o texto ou grupo selecionado. Limpe o filtro para voltar a tabela completa.";

    protected override async Task OnParametersSetAsync()
    {
        var requestedIds = (Ids ?? [])
            .SelectMany(value => value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            .Select(value => int.TryParse(value, out var id) ? id : 0)
            .Where(id => id > 0)
            .Distinct()
            .Take(4)
            .ToList();
        HasRequestedIds = requestedIds.Count > 0;

        SelectedIds = HasRequestedIds
            ? requestedIds
            : CompareSelection.Ids
                .Take(4)
                .ToList();

        if (QuickStartPhones.Count == 0)
        {
            QuickStartPhones = await Catalog.GetQuickStartPhonesAsync(6, CancellationToken.None);
        }

        await LoadComparisonAsync();

        if (!HasRequestedIds && SelectedIds.Count > 0)
        {
            Navigation.NavigateTo(BuildCompareUrl(), replace: true);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var restoredSelection = await CompareSelection.EnsureHydratedAsync();
        if (restoredSelection &&
            !HasRequestedIds &&
            SelectedIds.Count == 0 &&
            CompareSelection.Count > 0)
        {
            SelectedIds = CompareSelection.Ids
                .Take(4)
                .ToList();
            await LoadComparisonAsync();
            Navigation.NavigateTo(BuildCompareUrl(), replace: true);
        }

        if (restoredSelection)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnSearchChanged(ChangeEventArgs args)
    {
        SearchText = args.Value?.ToString()?.TrimStart() ?? "";
        if (!string.IsNullOrWhiteSpace(SearchText))
        {
            OpenSuggestionPanel();
        }

        await QueueSearchRefreshAsync();
    }

    private async Task OnSearchFocused(FocusEventArgs _)
    {
        OpenSuggestionPanel();
        await RefreshSuggestionsAsync(CancellationToken.None);
    }

    private async Task OnSearchBlur(FocusEventArgs _)
    {
        await CloseSuggestionPanelAfterDelayAsync();
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs args)
    {
        switch (args.Key)
        {
            case "ArrowDown":
                MoveActiveSuggestion(1);
                break;
            case "ArrowUp":
                MoveActiveSuggestion(-1);
                break;
            case "Escape":
                Suggestions = [];
                ActiveSuggestionIndex = -1;
                CloseSuggestionPanel();
                break;
            case "Enter":
                if (HasSuggestions)
                {
                    await ActivateActiveSuggestionAsync();
                }

                break;
        }
    }

