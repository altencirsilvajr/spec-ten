    private static string? CellClass(CompareRowDto row, int phoneId, bool isMissing)
    {
        if (isMissing)
        {
            return "missing";
        }

        return row.WinnerPhoneId == phoneId ? "winner" : null;
    }

    private static string MobileCompareValue(string value)
    {
        return value == "-"
            ? "Nao publicado"
            : value;
    }

    private int WinnerCount(int phoneId)
    {
        return VisibleRows.Count(row => row.WinnerPhoneId == phoneId);
    }

    private int MissingCount(int phoneId)
    {
        return VisibleRows.Count(row => row.Values.GetValueOrDefault(phoneId, "-") == "-");
    }

    private int AvailableSpecCount(int phoneId)
    {
        return CoverageRows.Count(row => row.Values.GetValueOrDefault(phoneId, "-") != "-");
    }

    private int CoveragePercent(int phoneId)
    {
        if (CoverageRows.Count == 0)
        {
            return 0;
        }

        return (int)Math.Round(AvailableSpecCount(phoneId) * 100d / CoverageRows.Count, MidpointRounding.AwayFromZero);
    }

    private int? ResolveTopWinnerId()
    {
        var counts = Comparison.Phones
            .Select(phone => new { phone.Id, Count = WinnerCount(phone.Id) })
            .OrderByDescending(item => item.Count)
            .ToList();

        if (counts.Count == 0 || counts[0].Count == 0)
        {
            return null;
        }

        return counts.Count(item => item.Count == counts[0].Count) == 1
            ? counts[0].Id
            : null;
    }

    private static bool RowHasExactTie(CompareRowDto row)
    {
        var values = row.Values.Values
            .Where(value => value != "-")
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        return values.Count == 1 && row.Values.Values.Count(value => value != "-") >= 2;
    }

    private static string SectionAnchor(string name)
    {
        return $"compare-{Slugger.Slugify(name)}";
    }

    private void ToggleMobileSection(CompareSectionViewModel section)
    {
        var key = SectionKey(section.Name);
        MobileSectionExpanded[key] = !IsMobileSectionExpanded(section);
    }

    private bool IsMobileSectionExpanded(CompareSectionViewModel section)
    {
        var key = SectionKey(section.Name);
        if (MobileSectionExpanded.TryGetValue(key, out var isExpanded))
        {
            return isExpanded;
        }

        return VisibleSections
            .Take(2)
            .Any(item => string.Equals(SectionKey(item.Name), key, StringComparison.Ordinal));
    }

    private void ExpandAllMobileSections()
    {
        foreach (var section in VisibleSections)
        {
            MobileSectionExpanded[SectionKey(section.Name)] = true;
        }
    }

    private void RestoreEssentialMobileSections()
    {
        var essentialKeys = VisibleSections
            .Take(2)
            .Select(section => SectionKey(section.Name))
            .ToHashSet(StringComparer.Ordinal);

        foreach (var section in VisibleSections)
        {
            MobileSectionExpanded[SectionKey(section.Name)] = essentialKeys.Contains(SectionKey(section.Name));
        }
    }

    private void PruneMobileSectionState()
    {
        var visibleKeys = VisibleSections
            .Select(section => SectionKey(section.Name))
            .ToHashSet(StringComparer.Ordinal);

        foreach (var staleKey in MobileSectionExpanded.Keys.Where(key => !visibleKeys.Contains(key)).ToList())
        {
            MobileSectionExpanded.Remove(staleKey);
        }
    }

    private static string SectionKey(string name)
    {
        return SectionAnchor(name);
    }

    private IReadOnlyList<CompareRowDto> BuildSearchMatchedRows()
    {
        if (string.IsNullOrWhiteSpace(TableFilterText))
        {
            return Comparison.Rows;
        }

        var query = TableFilterText.Trim();
        return Comparison.Rows
            .Where(row => row.Group.Contains(query, StringComparison.OrdinalIgnoreCase) ||
                          row.DisplayName.Contains(query, StringComparison.OrdinalIgnoreCase) ||
                          row.Key.Contains(query, StringComparison.OrdinalIgnoreCase) ||
                          row.Values.Values.Any(value => value.Contains(query, StringComparison.OrdinalIgnoreCase)))
            .ToList();
    }

    private IReadOnlyList<CompareRowDto> BuildGroupMatchedRows()
    {
        return string.IsNullOrWhiteSpace(SelectedGroupFilter)
            ? SearchMatchedRows
            : SearchMatchedRows
                .Where(row => row.Group.Equals(SelectedGroupFilter, StringComparison.OrdinalIgnoreCase))
                .ToList();
    }

    private IReadOnlyList<CompareRowDto> BuildVisibleRows()
    {
        return OnlyDifferences
            ? GroupMatchedRows.Where(RowShowsDifference).ToList()
            : GroupMatchedRows;
    }

    private IReadOnlyList<CompareGroupFilterViewModel> BuildCompareGroupFilters()
    {
        var filters = SearchMatchedRows
            .GroupBy(row => row.Group)
            .OrderBy(group => group.Key, StringComparer.OrdinalIgnoreCase)
            .Select(group => new CompareGroupFilterViewModel(group.Key, group.Key, group.Count()))
            .ToList();

        return
        [
            new CompareGroupFilterViewModel("", "Todas", SearchMatchedRows.Count),
            .. filters
        ];
    }

    private void EnsureSelectedGroupFilterIsVisible()
    {
        if (string.IsNullOrWhiteSpace(SelectedGroupFilter))
        {
            return;
        }

        if (!SearchMatchedRows.Any(row => row.Group.Equals(SelectedGroupFilter, StringComparison.OrdinalIgnoreCase)))
        {
            SelectedGroupFilter = "";
        }
    }

    private static bool RowShowsDifference(CompareRowDto row)
    {
        return row.Values.Values
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count() > 1;
    }

    private IReadOnlyList<CompareHighlightViewModel> BuildComparisonHighlights(IReadOnlyList<CompareRowDto> rows)
    {
        if (!CanRenderComparisonTable || rows.Count == 0)
        {
            return [];
        }

        var definitions = new[]
        {
            new CompareHighlightDefinition("Performance", "benchmark_score", "chipset"),
            new CompareHighlightDefinition("Memoria", "ram", "storage_base"),
            new CompareHighlightDefinition("Tela", "display_size", "resolution", "refresh_rate"),
            new CompareHighlightDefinition("Camera", "main_camera", "ultrawide_camera", "selfie_camera"),
            new CompareHighlightDefinition("Bateria", "battery", "charging", "wireless_charging"),
            new CompareHighlightDefinition("Peso", "weight"),
        };

        var highlights = new List<CompareHighlightViewModel>();
        foreach (var definition in definitions)
        {
            var row = definition.Keys
                .Select(key => rows.FirstOrDefault(item => item.Key == key))
                .FirstOrDefault(item => item is not null);

            if (row is null)
            {
                continue;
            }

            var availableValues = Comparison.Phones
                .Select(phone => new CompareHighlightValue(
                    phone.Id,
                    phone.FullName,
                    row.Values.GetValueOrDefault(phone.Id, "-")))
                .Where(item => item.Value != "-")
                .ToList();

            if (availableValues.Count < 2)
            {
                continue;
            }

            var winnerPhone = row.WinnerPhoneId is null
                ? null
                : Comparison.Phones.FirstOrDefault(phone => phone.Id == row.WinnerPhoneId.Value);
            var leadingLabel = winnerPhone?.FullName
                               ?? (RowHasExactTie(row)
                                   ? "Empate entre os modelos atuais"
                                   : "Leitura lado a lado");
            var description = $"{row.DisplayName} em destaque";
            var valueSummary = winnerPhone is null
                ? string.Join(" · ", availableValues.Take(Comparison.Phones.Count == 2 ? 2 : 3).Select(item => $"{ModelLabel(item.PhoneName)}: {item.Value}"))
                : BuildWinnerSummary(winnerPhone.FullName, row.Values.GetValueOrDefault(winnerPhone.Id, "-"), availableValues);

            highlights.Add(new CompareHighlightViewModel(
                definition.Title,
                leadingLabel,
                description,
                valueSummary,
                winnerPhone?.Id));
        }

        return highlights;
    }

    private static string BuildWinnerSummary(string winnerPhoneName, string winnerValue, IReadOnlyList<CompareHighlightValue> availableValues)
    {
        var otherValues = availableValues
            .Where(item => !item.PhoneName.Equals(winnerPhoneName, StringComparison.OrdinalIgnoreCase))
            .Take(2)
            .Select(item => $"{ModelLabel(item.PhoneName)}: {item.Value}")
            .ToList();

        var parts = new List<string>
        {
            $"{winnerValue} em {ModelLabel(winnerPhoneName)}",
        };

        if (otherValues.Count > 0)
        {
            parts.AddRange(otherValues);
        }

        return string.Join(" · ", parts);
    }

    private static string ModelLabel(string fullName)
    {
        var parts = fullName.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length == 2 ? parts[1] : fullName;
    }

