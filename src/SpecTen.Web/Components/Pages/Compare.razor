    private async Task AddSuggestionAsync(PhoneSuggestionDto suggestion)
    {
        if (IsComparisonUpdating || SelectedIds.Contains(suggestion.Id) || SelectedIds.Count >= 4)
        {
            return;
        }

        await UpdateComparisonAsync(
            "Adicionando modelo ao comparador",
            $"Montando a comparacao com {suggestion.FullName}. Aguarde um instante.",
            async () =>
            {
                CancelPendingSearchRefresh(clearBusyState: true);
                SelectedIds.Add(suggestion.Id);
                SearchText = "";
                Suggestions = [];
                ActiveSuggestionIndex = -1;
                CloseSuggestionPanel();
                await LoadComparisonAsync();
                Navigation.NavigateTo(BuildCompareUrl(), replace: true);
            });
    }

    private async Task AddQuickStartPhoneAsync(PhoneSearchResult phone)
    {
        if (IsComparisonUpdating || !phone.HasFullCatalogEntry || SelectedIds.Contains(phone.Id) || SelectedIds.Count >= 4)
        {
            return;
        }

        await UpdateComparisonAsync(
            "Adicionando modelo ao comparador",
            $"Carregando as especificacoes de {phone.FullName}. Aguarde um instante.",
            async () =>
            {
                CancelPendingSearchRefresh(clearBusyState: true);
                SelectedIds.Add(phone.Id);
                SearchText = "";
                Suggestions = [];
                ActiveSuggestionIndex = -1;
                CloseSuggestionPanel();
                await LoadComparisonAsync();
                Navigation.NavigateTo(BuildCompareUrl(), replace: true);
            });
    }

    private async Task RemovePhoneAsync(int phoneId)
    {
        if (IsComparisonUpdating || !SelectedIds.Contains(phoneId))
        {
            return;
        }

        var phoneName = Comparison.Phones.FirstOrDefault(phone => phone.Id == phoneId)?.FullName ?? "o modelo";
        await UpdateComparisonAsync(
            "Atualizando comparacao",
            $"Removendo {phoneName} e recalculando as diferencas.",
            async () =>
            {
                SelectedIds.Remove(phoneId);
                CancelPendingSearchRefresh(clearBusyState: true);
                Suggestions = [];
                ActiveSuggestionIndex = -1;
                CloseSuggestionPanel();
                await LoadComparisonAsync();
                Navigation.NavigateTo(BuildCompareUrl(), replace: true);
            });
    }

    private async Task ClearSelection()
    {
        if (IsComparisonUpdating || SelectedIds.Count == 0)
        {
            return;
        }

        await UpdateComparisonAsync(
            "Limpando comparacao",
            "Removendo os modelos selecionados e preparando uma nova escolha.",
            async () =>
            {
                CancelPendingSearchRefresh(clearBusyState: true);
                SelectedIds.Clear();
                SearchText = "";
                Suggestions = [];
                ActiveSuggestionIndex = -1;
                OnlyDifferences = false;
                CloseSuggestionPanel();
                await LoadComparisonAsync();
