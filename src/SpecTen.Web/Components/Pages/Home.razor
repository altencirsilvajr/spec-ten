@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject CatalogService Catalog
@inject CompareSelectionState CompareSelection
@inject RecentlyViewedState RecentlyViewed
@inject NavigationManager Navigation

<PageTitle>SpecTen</PageTitle>
<HeadContent>
    <meta name="description" content="Catalogo mobile-first de celulares com specs, fontes, confianca e comparacao." />
    <meta property="og:title" content="SpecTen" />
    <meta property="og:description" content="Specs de celulares com origem dos dados e comparacao lado a lado." />
    <link rel="canonical" href="/" />
</HeadContent>

<section class="home-grid">
    <div class="search-panel">
        <p class="eyebrow">Catalogo mobile-first</p>
        <h1 class="page-title">Celulares, specs e comparacao sem tabela quebrada.</h1>
        <p class="page-lede">Busca instantanea, descoberta ampla de modelos recentes e comparacao preparada para mobile desde a primeira tela.</p>
        <div class="hero-actions">
            <a class="button primary" href="/celulares">Abrir catalogo</a>
            <a class="button subtle" href="/comparar">Comparar modelos</a>
            @if (SpotlightPhone is not null)
            {
                <a class="button subtle" href="/celulares/@SpotlightPhone.BrandSlug/@SpotlightPhone.Slug">Ver destaque</a>
            }
        </div>
        <div class="search-form toolbar-search">
            <label for="home-search">Buscar aparelho</label>
            <div class="search-row">
                <input id="home-search"
                       value="@SearchText"
                       @oninput="OnSearchChanged"
                       @onfocus="OnSearchFocused"
                       @onblur="OnSearchBlur"
                       @onkeydown="OnSearchKeyDown"
                       autocomplete="off"
                       autocapitalize="off"
                       autocorrect="off"
                       spellcheck="false"
                       inputmode="search"
                       role="combobox"
                       aria-autocomplete="list"
                       aria-expanded="@(HasSuggestions ? "true" : "false")"
                       aria-controls="home-suggestions"
                       aria-activedescendant="@ActiveSuggestionId"
                       placeholder="Galaxy S25, iPhone 16, Xiaomi 15T..." />
                <button class="button primary" type="button" @onclick="OpenCatalogSearch">Buscar</button>
            </div>

            <div class="search-assist-strip @SearchAssistTone" aria-live="polite">
                <strong>@SearchAssistTitle</strong>
                <span>@SearchAssistMessage</span>
            </div>

            @if (HasSuggestions)
            {
                <div id="home-suggestions" class="suggestion-panel" role="listbox" aria-label="Sugestoes da home">
                    @for (var index = 0; index < Suggestions.Count; index++)
                    {
                        var suggestion = Suggestions[index];
                        <button class="suggestion-item @(ActiveSuggestionIndex == index ? "active" : null)"
                                id="@SuggestionId(index)"
                                role="option"
                                aria-selected="@(ActiveSuggestionIndex == index)"
                                type="button"
                                @onclick="() => OpenSuggestion(suggestion)">
                            <span class="suggestion-title">@suggestion.FullName</span>
                            <span class="suggestion-meta">@SuggestionMeta(suggestion)</span>
                        </button>
                    }
                    <button class="suggestion-item more @(ActiveSuggestionIndex == Suggestions.Count ? "active" : null)"
                            id="@SuggestionId(Suggestions.Count)"
                            role="option"
                            aria-selected="@(ActiveSuggestionIndex == Suggestions.Count)"
                            type="button"
                            @onclick="OpenCatalogSearch">
                        <span class="suggestion-title">Ver resultados completos</span>
                        <span class="suggestion-meta">Abrir catalogo com a busca atual</span>
                    </button>
                </div>
            }
        </div>
    </div>

    <div class="quality-panel">
        <div>
            <span class="metric">@TotalModels</span>
            <span class="metric-label">fichas completas</span>
        </div>
        <div>
            <span class="metric">@TotalBrands</span>
            <span class="metric-label">marcas com ficha</span>
        </div>
        <div>
            <span class="metric">2-4</span>
            <span class="metric-label">aparelhos no comparador</span>
        </div>
    </div>
</section>

@if (HasResumeSection)
{
    <section class="resume-section" aria-label="Continuar de onde parou">
        <div class="section-heading compact">
            <div>
                <p class="eyebrow">Retomar sem atrito</p>
                <h2>Continue de onde voce parou</h2>
            </div>
            <p class="muted">Selecao do comparador e aparelhos vistos recentemente ficam prontos para reabrir sem digitar tudo de novo.</p>
        </div>

        <div class="resume-grid">
            @if (CompareSelection.Count > 0)
            {
                <article class="resume-card">
                    <span class="eyebrow">Comparacao pronta</span>
                    <strong>@CompareSelection.Count aparelho(s) aguardando</strong>
                    <p class="muted">@CompareResumeHint</p>
                    <div class="selected-chip-list">
                        @foreach (var selected in CompareSelection.Items)
                        {
                            <span class="selected-chip">@selected.FullName</span>
                        }
                    </div>
                    <div class="card-actions">
                        <a class="button primary" href="@CompareSelection.BuildCompareUrl()">Abrir comparador atual</a>
                        <button class="button subtle" type="button" @onclick="ClearComparison">Limpar comparacao</button>
                    </div>
                </article>
            }

            @if (RecentViews.Count > 0)
            {
                <article class="resume-card">
                    <span class="eyebrow">Vistos recentemente</span>
                    <strong>Volte para as ultimas fichas abertas</strong>
                    <p class="muted">Bom para rever modelos parecidos, abrir a ficha completa de novo ou entrar em uma comparacao a partir da memoria recente.</p>
                    <div class="jumpbar-list resume-recent-list">
                        @foreach (var item in RecentViews)
                        {
                            <a class="jump-chip" href="/celulares/@item.BrandSlug/@item.Slug">
                                <span>@item.FullName</span>
                                <span class="chip-secondary">@item.BadgeLabel</span>
                            </a>
                        }
                    </div>
                    <div class="card-actions">
                        <button class="button subtle" type="button" @onclick="ClearRecentlyViewed">Limpar historico</button>
                    </div>
                </article>
            }
        </div>
    </section>
}

<section class="home-launchpad-grid" aria-label="Acesso rapido da home">
    <article class="launchpad-panel">
        <strong class="jumpbar-label">Comecar rapido</strong>
        <div class="jumpbar-list">
            <a class="jump-chip" href="/celulares?classe=top#catalog-results">
                <span>Top de linha</span>
                <span class="chip-secondary">premium</span>
            </a>
            <a class="jump-chip" href="/celulares?classe=intermediario#catalog-results">
                <span>Intermediarios</span>
                <span class="chip-secondary">equilibrio</span>
            </a>
            <a class="jump-chip" href="/celulares?classe=entrada#catalog-results">
                <span>Entrada</span>
                <span class="chip-secondary">uso diario</span>
            </a>
            <a class="jump-chip" href="/comparar">
                <span>Comparador</span>
                <span class="chip-secondary">2 a 4 modelos</span>
            </a>
        </div>
    </article>

    @if (QuickStartPhones.Count > 0)
    {
        <article class="launchpad-panel">
            <strong class="jumpbar-label">Abrir agora</strong>
            <div class="jumpbar-list">
                @foreach (var phone in QuickStartPhones)
                {
                    <a class="jump-chip" href="/celulares/@phone.BrandSlug/@phone.Slug">
                        <span>@phone.FullName</span>
                        <span class="chip-secondary">@phone.Tier</span>
                    </a>
                }
            </div>
        </article>
    }

    @if (PopularComparisons.Count > 0)
    {
        <article class="launchpad-panel">
            <strong class="jumpbar-label">Comparacoes prontas</strong>
            <div class="jumpbar-list">
                @foreach (var preset in PopularComparisons)
                {
                    <a class="jump-chip" href="@PresetCompareUrl(preset)">
                        <span>@PresetTitle(preset)</span>
                        <span class="chip-secondary">@preset.Label</span>
                    </a>
                }
            </div>
        </article>
    }

    @if (PopularBrands.Count > 0)
    {
        <article class="launchpad-panel">
            <strong class="jumpbar-label">Explorar por marca</strong>
            <div class="jumpbar-list">
                @foreach (var brand in PopularBrands)
                {
                    <a class="jump-chip" href="/celulares?marca=@brand.Slug#catalog-results">
                        <span>@brand.Name</span>
                        <span class="chip-secondary">@brand.Count</span>
                    </a>
                }
            </div>
        </article>
    }
</section>

<section class="section-heading">
    <div>
        <p class="eyebrow">Destaques</p>
        <h2>Aparelhos recentes</h2>
    </div>
    <a class="button subtle" href="/celulares">Ver todos</a>
</section>

<div class="phone-grid home-feature-grid">
    @foreach (var phone in Featured)
    {
        <article class="phone-card">
            <a class="phone-card-media media-frame" href="/celulares/@phone.BrandSlug/@phone.Slug" aria-label="@phone.FullName">
                <PhoneMediaContent ImageUrl="@phone.ImageUrl"
                                   Alt="@phone.FullName"
                                   Brand="@phone.DisplayBrand"
                                   Model="@phone.ModelName" />
            </a>
            <div class="phone-card-body">
                <div>
                    <p class="muted">@phone.DisplayBrand</p>
                    <h3><a href="/celulares/@phone.BrandSlug/@phone.Slug">@phone.ModelName</a></h3>
                    <p class="catalog-meta">@CardMeta(phone)</p>
                </div>
                <span class="tier">@phone.PrimaryBadgeLabel</span>
                <dl class="spec-pills">
                    <div>
                        <dt>Chipset</dt>
                        <dd>@CompactChipset(phone.Chipset)</dd>
                    </div>
                    <div>
                        <dt>Bateria</dt>
                        <dd>@(phone.Battery ?? "-")</dd>
                    </div>
                </dl>
            </div>
        </article>
    }
</div>

@code {
    private IReadOnlyList<PhoneSearchResult> Featured { get; set; } = [];
    private IReadOnlyList<PhoneSearchResult> QuickStartPhones { get; set; } = [];
    private IReadOnlyList<ComparisonQuickStartDto> PopularComparisons { get; set; } = [];
    private IReadOnlyList<PhoneSuggestionDto> Suggestions { get; set; } = [];
    private IReadOnlyList<HomeBrandLink> PopularBrands { get; set; } = [];
    private string SearchText { get; set; } = "";
    private int TotalModels { get; set; }
    private int TotalBrands { get; set; }
    private int ActiveSuggestionIndex { get; set; } = -1;
    private const int SearchDebounceMilliseconds = 180;
    private const int SuggestionCloseDelayMilliseconds = 120;
    private bool IsSearchRefreshing { get; set; }
    private CancellationTokenSource? _searchDebounceCts;
    private CancellationTokenSource? _suggestionCloseCts;
    private bool IsSuggestionPanelOpen { get; set; }
    private bool HasSuggestions => IsSuggestionPanelOpen && Suggestions.Count > 0 && !string.IsNullOrWhiteSpace(SearchText);
    private int SuggestionOptionCount => HasSuggestions ? Suggestions.Count + 1 : 0;
    private string? ActiveSuggestionId => ActiveSuggestionIndex >= 0 ? SuggestionId(ActiveSuggestionIndex) : null;
    private int FullSuggestionCount => Suggestions.Count(item => item.IsPublicReady);
    private int PartialSuggestionCount => Suggestions.Count(item => item.IsPartialCatalogEntry);
    private int CoverageSuggestionCount => Suggestions.Count(item => !item.HasFullCatalogEntry);
    private IReadOnlyList<RecentlyViewedItem> RecentViews => RecentlyViewed.Items.Take(6).ToList();
    private PhoneSearchResult? SpotlightPhone => QuickStartPhones.FirstOrDefault() ?? Featured.FirstOrDefault();
    private bool HasResumeSection => CompareSelection.Count > 0 || RecentViews.Count > 0;
    private string CompareResumeHint => CompareSelection.Count switch
    {
        1 => "Falta mais um modelo para liberar a tabela comparativa completa.",
        4 => "Selecao cheia. Abra a tabela ou troque um aparelho antes de testar outra combinacao.",
        _ => "A selecao ja esta pronta para abrir a tabela lado a lado imediatamente.",
    };
    private SearchAssistViewModel SearchAssist => BuildSearchAssist();
    private string SearchAssistTitle => SearchAssist.Title;
    private string SearchAssistMessage => SearchAssist.Message;
    private string SearchAssistTone => SearchAssist.Tone;

    protected override async Task OnInitializedAsync()
    {
        CompareSelection.Changed += OnClientStateChanged;
        RecentlyViewed.Changed += OnClientStateChanged;

        var phones = await Catalog.SearchAsync(null, null, 40, CancellationToken.None);
        var quickStartPhones = await Catalog.GetQuickStartPhonesAsync(8, CancellationToken.None);
        var popularComparisons = await Catalog.GetPopularComparisonsAsync(4, CancellationToken.None);

        var readyPhones = phones.Where(phone => phone.IsPublicReady).ToList();

        TotalModels = readyPhones.Count;
        TotalBrands = readyPhones.Select(phone => phone.BrandSlug).Distinct(StringComparer.OrdinalIgnoreCase).Count();
        PopularBrands = readyPhones
            .GroupBy(phone => phone.BrandSlug, StringComparer.OrdinalIgnoreCase)
            .Select(group => new HomeBrandLink(group.First().Brand, group.Key, group.Count()))
            .OrderByDescending(brand => brand.Count)
            .ThenBy(brand => brand.Name, StringComparer.OrdinalIgnoreCase)
            .Take(5)
            .ToList();
        QuickStartPhones = quickStartPhones.Take(4).ToList();
        PopularComparisons = popularComparisons;
        Featured = quickStartPhones.Take(4).ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var compareChanged = await CompareSelection.EnsureHydratedAsync();
        var historyChanged = await RecentlyViewed.EnsureHydratedAsync();
        if (compareChanged || historyChanged)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnSearchChanged(ChangeEventArgs args)
    {
        SearchText = args.Value?.ToString()?.TrimStart() ?? "";
        if (!string.IsNullOrWhiteSpace(SearchText))
        {
            OpenSuggestionPanel();
        }

        await QueueSearchRefreshAsync();
    }

    private async Task OnSearchFocused(FocusEventArgs _)
    {
        OpenSuggestionPanel();
        await RefreshSuggestionsAsync(CancellationToken.None);
    }

    private async Task OnSearchBlur(FocusEventArgs _)
    {
        await CloseSuggestionPanelAfterDelayAsync();
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs args)
    {
        switch (args.Key)
        {
            case "ArrowDown":
                MoveActiveSuggestion(1);
                break;
            case "ArrowUp":
                MoveActiveSuggestion(-1);
                break;
            case "Escape":
                Suggestions = [];
                ActiveSuggestionIndex = -1;
                CloseSuggestionPanel();
                break;
            case "Enter":
                if (HasSuggestions)
                {
                    await ActivateActiveSuggestionAsync();
                }
                else
                {
                    OpenCatalogSearch();
                }

                break;
        }
    }

    private async Task QueueSearchRefreshAsync()
    {
        CancelPendingSearchRefresh(clearBusyState: false);
        if (string.IsNullOrWhiteSpace(SearchText))
        {
            Suggestions = [];
            ActiveSuggestionIndex = -1;
            IsSearchRefreshing = false;
            return;
        }

        var debounceCts = new CancellationTokenSource();
        _searchDebounceCts = debounceCts;
        IsSearchRefreshing = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(SearchDebounceMilliseconds, debounceCts.Token);
            await RefreshSuggestionsAsync(debounceCts.Token);
        }
        catch (OperationCanceledException) when (debounceCts.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_searchDebounceCts, debounceCts))
            {
                _searchDebounceCts = null;
                IsSearchRefreshing = false;
                await InvokeAsync(StateHasChanged);
            }

            debounceCts.Dispose();
        }
    }

    private async Task RefreshSuggestionsAsync(CancellationToken cancellationToken)
    {
        Suggestions = string.IsNullOrWhiteSpace(SearchText)
            ? []
            : await Catalog.SuggestForLiveDiscoveryAsync(SearchText, 6, cancellationToken);
        ResetSuggestionSelection();
    }

    private void OpenSuggestion(PhoneSuggestionDto suggestion)
    {
        CancelPendingSearchRefresh(clearBusyState: true);
        Suggestions = [];
        ActiveSuggestionIndex = -1;
        CloseSuggestionPanel();
        Navigation.NavigateTo($"/celulares/{suggestion.BrandSlug}/{suggestion.Slug}");
    }

    private void OpenCatalogSearch()
    {
        CancelPendingSearchRefresh(clearBusyState: true);
        Suggestions = [];
        ActiveSuggestionIndex = -1;
        CloseSuggestionPanel();
        if (string.IsNullOrWhiteSpace(SearchText))
        {
            Navigation.NavigateTo("/celulares");
            return;
        }

        var targetUrl = Navigation.GetUriWithQueryParameters("/celulares", new Dictionary<string, object?>
        {
            ["busca"] = SearchText,
        });

        Navigation.NavigateTo($"{targetUrl}#catalog-results");
    }

    private void ClearComparison()
    {
        CompareSelection.Clear();
    }

    private void ClearRecentlyViewed()
    {
        RecentlyViewed.Clear();
    }

    private async Task ActivateActiveSuggestionAsync()
    {
        if (ActiveSuggestionIndex < 0 || ActiveSuggestionIndex >= SuggestionOptionCount)
        {
            OpenCatalogSearch();
            return;
        }

        if (ActiveSuggestionIndex < Suggestions.Count)
        {
            OpenSuggestion(Suggestions[ActiveSuggestionIndex]);
            return;
        }

        OpenCatalogSearch();
        await Task.CompletedTask;
    }

    private void MoveActiveSuggestion(int step)
    {
        if (SuggestionOptionCount == 0)
        {
            ActiveSuggestionIndex = -1;
            return;
        }

        ActiveSuggestionIndex = ActiveSuggestionIndex < 0
            ? 0
            : (ActiveSuggestionIndex + step + SuggestionOptionCount) % SuggestionOptionCount;
    }

    private void ResetSuggestionSelection()
    {
        ActiveSuggestionIndex = Suggestions.Count > 0 ? 0 : -1;
    }

    private void OpenSuggestionPanel()
    {
        CancelPendingSuggestionClose();
        IsSuggestionPanelOpen = true;
    }

    private async Task CloseSuggestionPanelAfterDelayAsync()
    {
        CancelPendingSuggestionClose();
        var closeCts = new CancellationTokenSource();
        _suggestionCloseCts = closeCts;

        try
        {
            await Task.Delay(SuggestionCloseDelayMilliseconds, closeCts.Token);
            if (!ReferenceEquals(_suggestionCloseCts, closeCts))
            {
                return;
            }

            IsSuggestionPanelOpen = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) when (closeCts.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_suggestionCloseCts, closeCts))
            {
                _suggestionCloseCts = null;
            }

            closeCts.Dispose();
        }
    }

    private void CloseSuggestionPanel()
    {
        CancelPendingSuggestionClose();
        IsSuggestionPanelOpen = false;
    }

    private void CancelPendingSuggestionClose()
    {
        _suggestionCloseCts?.Cancel();
        _suggestionCloseCts = null;
    }

    private void CancelPendingSearchRefresh(bool clearBusyState)
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts = null;

        if (clearBusyState)
        {
            IsSearchRefreshing = false;
        }
    }

    private SearchAssistViewModel BuildSearchAssist()
    {
        if (IsSearchRefreshing)
        {
            return new SearchAssistViewModel(
                "Buscando modelos",
                $"Separando as melhores sugestoes para \"{SearchText}\".",
                "loading");
        }

        if (string.IsNullOrWhiteSpace(SearchText))
        {
            return new SearchAssistViewModel(
                "Busca com cobertura ampla",
                "Digite o nome do aparelho, a marca ou o chipset para ver opcoes enquanto voce escreve.",
                "neutral");
        }

        if (Suggestions.Count == 0)
        {
            return new SearchAssistViewModel(
                "Sem sugestao imediata",
                "Abra o catalogo completo ou tente uma linha mais ampla como a marca e a familia do aparelho.",
                "neutral");
        }

        if (FullSuggestionCount > 0 && (PartialSuggestionCount > 0 || CoverageSuggestionCount > 0))
        {
            return new SearchAssistViewModel(
                $"{Suggestions.Count} sugestoes encontradas",
                $"{FullSuggestionCount} prontas, {PartialSuggestionCount} parcial(is) e {CoverageSuggestionCount} em cobertura inicial.",
                "good");
        }

        if (FullSuggestionCount > 0)
        {
            return new SearchAssistViewModel(
                $"{FullSuggestionCount} opcoes prontas",
                "Pressione Enter para abrir a primeira ou toque na sugestao desejada.",
                "good");
        }

        if (PartialSuggestionCount > 0)
        {
            return new SearchAssistViewModel(
                $"{PartialSuggestionCount} ficha(s) parcial(is)",
                "Esses modelos ja tem parte da ficha, mas ainda nao entram como promessa publica completa.",
                "warn");
        }

        return new SearchAssistViewModel(
            "Cobertura inicial encontrada",
            "Mesmo sem ficha completa, esses modelos ja aparecem na busca publica.",
            "warn");
    }

    private static string SuggestionId(int index)
    {
        return $"home-suggestion-{index}";
    }

    private static string SuggestionMeta(PhoneSuggestionDto suggestion)
    {
        if (!suggestion.HasFullCatalogEntry)
        {
            return "Cobertura inicial · ficha completa em preparacao";
        }

        return string.IsNullOrWhiteSpace(suggestion.Chipset)
            ? suggestion.PrimaryBadgeLabel
            : $"{suggestion.PrimaryBadgeLabel} · {CompactChipset(suggestion.Chipset)}";
    }

    private static string PresetTitle(ComparisonQuickStartDto preset)
    {
        return $"{preset.Left.ModelName} x {preset.Right.ModelName}";
    }

    private static string PresetPhoneMeta(PhoneSearchResult phone)
    {
        return string.IsNullOrWhiteSpace(phone.Chipset)
            ? phone.Tier
            : $"{phone.Tier} · {CompactChipset(phone.Chipset)}";
    }

    private static string PresetCompareUrl(ComparisonQuickStartDto preset)
    {
        return $"/comparar?ids={preset.Left.Id},{preset.Right.Id}";
    }

    private static string FormatRelease(DateTimeOffset? releasedAt)
    {
        return releasedAt is null
            ? "Sem data publicada"
            : $"Lancado em {releasedAt.Value:MMM yyyy}";
    }

    private static string CardMeta(PhoneSearchResult phone)
    {
        var parts = new List<string>
        {
            FormatRelease(phone.ReleasedAt),
        };

        if (phone.LaunchPriceUsd is not null)
        {
            parts.Add($"US$ {phone.LaunchPriceUsd.Value:0}");
        }

        parts.Add($"{phone.TrustLabel} · confianca {phone.MinConfidence.ToString("P0")}");
        parts.Add(FreshnessFormatter.UpdatedLabel(phone.UpdatedAt));
        return string.Join(" · ", parts);
    }

    private static string CompactChipset(string? chipset)
    {
        var compact = PhoneNameFormatter.CompactChipset(chipset);
        return string.IsNullOrWhiteSpace(compact) ? "-" : compact;
    }

    private sealed record SearchAssistViewModel(string Title, string Message, string Tone);
    private sealed record HomeBrandLink(string Name, string Slug, int Count);

    private void OnClientStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        CompareSelection.Changed -= OnClientStateChanged;
        RecentlyViewed.Changed -= OnClientStateChanged;
        CancelPendingSearchRefresh(clearBusyState: false);
        CancelPendingSuggestionClose();
    }
}
