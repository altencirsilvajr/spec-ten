@if (!string.IsNullOrWhiteSpace(ImageUrl))
{
    <img src="@ImageUrl"
         alt="@Alt"
         loading="@Loading"
         onerror="this.classList.add('is-hidden'); var host = this.closest('.media-frame'); if (host) { host.classList.add('image-failed'); }" />
}

<div class="media-placeholder @(HasImage ? "fallback-hidden" : null)" aria-label="Imagem do aparelho em verificacao">
    <span class="media-placeholder-label">Imagem em verificacao</span>
    <span class="media-placeholder-icon" aria-hidden="true">SP</span>
    <strong>@Brand @Model</strong>
    <small>Estamos confirmando uma imagem publica para esta ficha.</small>
</div>

@code {
    [Parameter]
    public string? ImageUrl { get; set; }

    [Parameter]
    public string Alt { get; set; } = "";

    [Parameter]
    public string Brand { get; set; } = "";

    [Parameter]
    public string Model { get; set; } = "";

    [Parameter]
    public string Loading { get; set; } = "lazy";

    private bool HasImage => !string.IsNullOrWhiteSpace(ImageUrl);
}
